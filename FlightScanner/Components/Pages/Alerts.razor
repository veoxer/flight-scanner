@page "/alerts"
@attribute [Authorize]
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime Js

<PageTitle>@UiText.T("Alerts")</PageTitle>

<div class="page-title-row">
    <h1>@UiText.T("PriceAlerts")</h1>
    <button class="btn btn-outline-primary" @onclick="EnableNotificationsAsync">@UiText.T("EnableNotifications")</button>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

@if (alerts.Count == 0)
{
    <div class="empty-state">
        <h2>@UiText.T("NoAlertsYet")</h2>
        <p>@UiText.T("NoAlertsText")</p>
        <a class="btn btn-primary" href="search">@UiText.T("CreateAlert")</a>
    </div>
}
else
{
    <div class="alert-list">
        @foreach (var alert in alerts)
        {
            <article class="alert-row">
                <div>
                    <strong>@alert.Origin @UiText.T("ToLower") @alert.Destination</strong>
                    <span>@alert.DepartFrom.ToString("yyyy-MM-dd") @UiText.T("ToLower") @alert.DepartTo.ToString("yyyy-MM-dd") - @alert.Adults @UiText.T("Adults") - @alert.Cabin</span>
                </div>
                <div>
                    <strong>@alert.TargetPrice.ToString("0.##") @alert.Currency</strong>
                    <span>@UiText.T("LastSeen"): @(alert.LastObservedPrice?.ToString("0.##") ?? UiText.T("NotChecked"))</span>
                </div>
                <div class="row-actions">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleAsync(alert.Id)">@(alert.IsActive ? UiText.T("Pause") : UiText.T("Resume"))</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(alert.Id)">@UiText.T("Delete")</button>
                </div>
            </article>
        }
    </div>
}

<h2 class="mt-4">@UiText.T("RecentNotifications")</h2>
<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@UiText.T("When")</th>
                <th>@UiText.T("Channel")</th>
                <th>@UiText.T("Status")</th>
                <th>@UiText.T("Message")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var attempt in attempts)
            {
                <tr>
                    <td>@attempt.CreatedAt.LocalDateTime.ToString("g")</td>
                    <td>@attempt.Channel</td>
                    <td>@(attempt.Succeeded ? UiText.T("Sent") : UiText.T("Failed"))</td>
                    <td>@attempt.Subject</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<PriceAlert> alerts = [];
    private List<NotificationAttempt> attempts = [];
    private string? userId;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        alerts = await db.PriceAlerts
            .Where(alert => alert.UserId == userId)
            .OrderByDescending(alert => alert.CreatedAt)
            .ToListAsync();
        attempts = await db.NotificationAttempts
            .Where(attempt => attempt.Recipient == userId || alerts.Select(alert => (int?)alert.Id).Contains(attempt.PriceAlertId))
            .OrderByDescending(attempt => attempt.CreatedAt)
            .Take(20)
            .ToListAsync();
    }

    private async Task ToggleAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var alert = await db.PriceAlerts.FirstAsync(item => item.Id == id && item.UserId == userId);
        alert.IsActive = !alert.IsActive;
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var alert = await db.PriceAlerts.FirstAsync(item => item.Id == id && item.UserId == userId);
        db.PriceAlerts.Remove(alert);
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task EnableNotificationsAsync()
    {
        var permission = await Js.InvokeAsync<string>("flightNotifications.requestPermission");
        var subscription = await Js.InvokeAsync<string>("flightNotifications.subscribePush");
        message = subscription switch
        {
            "subscribed" => UiText.T("PushEnabled"),
            "missing-public-key" => UiText.T("PushMissingKey"),
            "unsupported" => UiText.T("PushUnsupported"),
            _ => string.Format(System.Globalization.CultureInfo.CurrentCulture, UiText.T("NotificationPermission"), permission)
        };
    }
}
