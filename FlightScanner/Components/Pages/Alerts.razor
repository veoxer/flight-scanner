@page "/alerts"
@attribute [Authorize]
@using System.Globalization
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@UiText.T("Alerts")</PageTitle>

<div class="page-title-row">
    <h1 class="notification-title">@UiText.T("PriceAlerts")</h1>
    <button type="button"
            class="btn btn-outline-primary notification-action"
            data-enable-notifications
            data-status-subscribed="@UiText.T("PushEnabled")"
            data-status-missing-key="@UiText.T("PushMissingKey")"
            data-status-unsupported="@UiText.T("PushUnsupported")"
            data-status-permission="@UiText.T("NotificationPermission")">
        @UiText.T("EnableNotifications")
    </button>
</div>
<div class="notification-status" data-notification-status hidden></div>

@if (alerts.Count == 0)
{
    <div class="empty-state">
        <h2>@UiText.T("NoAlertsYet")</h2>
        <p>@UiText.T("NoAlertsText")</p>
        <a class="btn btn-primary" href="search">@UiText.T("CreateAlert")</a>
    </div>
}
else
{
    <div class="alert-list">
        @foreach (var alert in alerts)
        {
            <details class="alert-row alert-detail-card">
                <summary class="alert-summary">
                    <div>
                        <strong>@alert.Origin @UiText.T("ToLower") @alert.Destination</strong>
                        <span>@FormatAlertDates(alert) - @alert.Adults @UiText.T("Adults") - @alert.Cabin</span>
                    </div>
                    <div>
                        <strong>@FormatAlertTargets(alert)</strong>
                        <span>@UiText.T("LastSeen"): @(alert.LastObservedPrice?.ToString("0.##") ?? UiText.T("NotChecked"))</span>
                    </div>
                    <div>
                        <strong>@(alert.IsActive ? UiText.T("Active") : UiText.T("Paused"))</strong>
                        <span>@UiText.T("Created"): @alert.CreatedAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)</span>
                    </div>
                    <span class="expand-chevron" aria-hidden="true">⌄</span>
                </summary>

                <div class="alert-detail-grid">
                    <div>
                        <strong>@UiText.T("Route")</strong>
                        <span>@UiText.T("From"): @alert.OriginType / @alert.Origin</span>
                        <span>@UiText.T("To"): @alert.DestinationType / @alert.Destination</span>
                        <span>@UiText.T("TripType"): @(alert.ReturnFrom is null ? UiText.T("OneWay") : UiText.T("Return"))</span>
                    </div>
                    <div>
                        <strong>@UiText.T("Dates")</strong>
                        <span>@FormatAlertDates(alert)</span>
                        @if (alert.FlexibleDates)
                        {
                            <span>@UiText.T("DateMode"): @UiText.T("FlexibleDates")</span>
                        }
                        else
                        {
                            <span>@UiText.T("DateMode"): @UiText.T("SpecificDates")</span>
                        }
                    </div>
                    <div>
                        <strong>@UiText.T("TravellersCabin")</strong>
                        <span>@UiText.T("Adults"): @alert.Adults</span>
                        <span>@UiText.T("Children"): @alert.Children</span>
                        <span>@UiText.T("CabinClass"): @alert.Cabin</span>
                    </div>
                    <div>
                        <strong>@UiText.T("Filters")</strong>
                        <span>@UiText.T("DirectFlights"): @FormatBoolean(alert.DirectOnly)</span>
                        <span>@UiText.T("MaxStops"): @(alert.MaxStops?.ToString(CultureInfo.CurrentCulture) ?? "-")</span>
                        <span>@UiText.T("CheckedBags"): @alert.CheckedBags</span>
                        <span>@UiText.T("OutboundTime"): @FormatTimeWindow(alert.OutboundTimeFromHour, alert.OutboundTimeToHour)</span>
                        @if (alert.ReturnFrom is not null)
                        {
                            <span>@UiText.T("ReturnTime"): @FormatTimeWindow(alert.ReturnTimeFromHour, alert.ReturnTimeToHour)</span>
                        }
                        <span>@UiText.T("Currency"): @alert.Currency</span>
                    </div>
                    <div>
                        <strong>@UiText.T("AlertTarget")</strong>
                        <span>@FormatAlertTargets(alert)</span>
                        <span>@UiText.T("LastSeen"): @(alert.LastObservedPrice?.ToString("0.##", CultureInfo.CurrentCulture) ?? UiText.T("NotChecked"))</span>
                    </div>
                    <div>
                        <strong>@UiText.T("ScanStatus")</strong>
                        <span>@UiText.T("LastChecked"): @(alert.LastCheckedAt?.LocalDateTime.ToString("g", CultureInfo.CurrentCulture) ?? UiText.T("NotChecked"))</span>
                        <span>@UiText.T("LastMatched"): @(alert.LastMatchedAt?.LocalDateTime.ToString("g", CultureInfo.CurrentCulture) ?? UiText.T("NotChecked"))</span>
                    </div>
                </div>

                <div class="row-actions alert-detail-actions">
                    <form method="post" action="@($"/alerts/{alert.Id}/toggle")" class="inline-action-form">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">@(alert.IsActive ? UiText.T("Pause") : UiText.T("Resume"))</button>
                    </form>
                    <form method="post" action="@($"/alerts/{alert.Id}/delete")" class="inline-action-form">
                        <AntiforgeryToken />
                        <button type="button" class="btn btn-sm btn-outline-danger" data-confirm-delete-alert>@UiText.T("Delete")</button>
                    </form>
                </div>
            </details>
        }
    </div>
}

<div class="confirm-modal" data-alert-delete-modal hidden>
    <div class="confirm-backdrop" data-alert-delete-cancel></div>
    <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="delete-alert-title">
        <h2 id="delete-alert-title">@UiText.T("ConfirmDeleteAlertTitle")</h2>
        <p>@UiText.T("ConfirmDeleteAlertText")</p>
        <div class="confirm-actions">
            <button type="button" class="btn btn-outline-secondary" data-alert-delete-cancel>@UiText.T("Cancel")</button>
            <button type="button" class="btn btn-danger" data-alert-delete-confirm>@UiText.T("ConfirmDelete")</button>
        </div>
    </div>
</div>

<h2 class="mt-4">@UiText.T("RecentNotifications")</h2>
<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@UiText.T("When")</th>
                <th>@UiText.T("Channel")</th>
                <th>@UiText.T("Status")</th>
                <th>@UiText.T("Message")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var attempt in attempts)
            {
                <tr>
                    <td>@attempt.CreatedAt.LocalDateTime.ToString("g")</td>
                    <td>@attempt.Channel</td>
                    <td>@(attempt.Succeeded ? UiText.T("Sent") : UiText.T("Failed"))</td>
                    <td>@attempt.Subject</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<PriceAlert> alerts = [];
    private List<NotificationAttempt> attempts = [];
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        alerts = await db.PriceAlerts
            .Where(alert => alert.UserId == userId)
            .OrderByDescending(alert => alert.CreatedAt)
            .ToListAsync();
        attempts = await db.NotificationAttempts
            .Where(attempt => attempt.Recipient == userId || alerts.Select(alert => (int?)alert.Id).Contains(attempt.PriceAlertId))
            .OrderByDescending(attempt => attempt.CreatedAt)
            .Take(20)
            .ToListAsync();
    }

    private static string FormatAlertTargets(PriceAlert alert)
    {
        var parts = new List<string>();
        var maxTarget = alert.MaxTargetPrice ?? (!alert.TargetMode.Equals("Min", StringComparison.OrdinalIgnoreCase) && alert.TargetPrice > 0 ? alert.TargetPrice : null);
        var minTarget = alert.MinTargetPrice ?? (alert.TargetMode.Equals("Min", StringComparison.OrdinalIgnoreCase) && alert.TargetPrice > 0 ? alert.TargetPrice : null);

        if (maxTarget is not null)
        {
            parts.Add($"{UiText.T("MaxFare")}: {maxTarget.Value:0.##} {alert.Currency}");
        }

        if (minTarget is not null)
        {
            parts.Add($"{UiText.T("MinFare")}: {minTarget.Value:0.##} {alert.Currency}");
        }

        return parts.Count > 0 ? string.Join(" / ", parts) : $"{alert.TargetPrice:0.##} {alert.Currency}";
    }

    private static string FormatAlertDates(PriceAlert alert)
    {
        if (!alert.FlexibleDates)
        {
            return $"{alert.DepartFrom:yyyy-MM-dd} {UiText.T("ToLower")} {alert.DepartTo:yyyy-MM-dd}";
        }

        var monthName = alert.FlexibleMonth is >= 1 and <= 12
            ? CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(alert.FlexibleMonth.Value)
            : UiText.T("Month");
        var weekday = alert.FlexibleDepartureDay is { } day
            ? CultureInfo.CurrentCulture.DateTimeFormat.GetDayName(day)
            : UiText.T("Weekday");
        var stay = alert.ReturnFrom is null
            ? ""
            : $" / {alert.FlexibleStayDays ?? 1} {UiText.T("StayDays")}";
        return $"{UiText.T("FlexibleDates")}: {monthName} {alert.FlexibleYear} / {weekday}{stay}";
    }

    private static string FormatBoolean(bool value)
    {
        return value ? UiText.T("Yes") : UiText.T("No");
    }

    private static string FormatTimeWindow(int? fromHour, int? toHour)
    {
        if (fromHour is null && toHour is null)
        {
            return UiText.T("AnyTime");
        }

        return $"{FormatHour(fromHour ?? 0)} - {FormatHour(toHour ?? 23)}";
    }

    private static string FormatHour(int hour)
    {
        return $"{Math.Clamp(hour, 0, 23):00}:00";
    }
}
