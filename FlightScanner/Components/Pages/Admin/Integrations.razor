@page "/admin/integrations"
@attribute [Authorize(Roles = "Admin")]
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>@UiText.T("FlightIntegrations")</PageTitle>

<h1>@UiText.T("FlightIntegrations")</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}

<EditForm Model="Input" method="post" OnValidSubmit="SaveAsync" FormName="flight-provider-settings">
    <DataAnnotationsValidator />
    <section class="tool-surface">
        <h2>@UiText.T("FlightProviderApi")</h2>
        <p class="settings-note">@UiText.T("FlightProviderText")</p>

        <label class="form-label">@UiText.T("Provider")</label>
        <InputSelect class="form-select" @bind-Value="Input.ProviderType">
            <option value="Amadeus">Amadeus Flight Offers</option>
            <option value="Custom">Custom HTTP API</option>
        </InputSelect>

        <div class="settings-grid mt-3">
            <section>
                <h2>Amadeus</h2>
                <label class="form-label">@UiText.T("Environment")</label>
                <InputSelect class="form-select" @bind-Value="Input.AmadeusEnvironment">
                    <option value="Test">@UiText.T("TestCachedData")</option>
                    <option value="Production">@UiText.T("ProductionRealtimeData")</option>
                </InputSelect>
                <label class="form-label mt-3">@UiText.T("ApiKey")</label>
                <InputText class="form-control" @bind-Value="Input.AmadeusClientId" />
                <label class="form-label mt-3">@UiText.T("ApiSecret")</label>
                <InputText class="form-control" type="password" @bind-Value="Input.AmadeusClientSecret" />
                <label class="form-label mt-3">@UiText.T("MaxOffers")</label>
                <InputNumber class="form-control" @bind-Value="Input.AmadeusMaxOffers" />
            </section>

            <section>
                <h2>Custom HTTP API</h2>
                <label class="form-label">@UiText.T("EndpointUrl")</label>
                <InputText class="form-control" @bind-Value="Input.EndpointUrl" />
                <label class="form-label mt-3">@UiText.T("HttpMethod")</label>
                <InputText class="form-control" @bind-Value="Input.HttpMethod" />
                <label class="form-label mt-3">@UiText.T("HeadersJson")</label>
                <InputTextArea class="form-control code-box" @bind-Value="Input.HeadersJson" />
                <label class="form-label mt-3">@UiText.T("BodyTemplate")</label>
                <InputTextArea class="form-control code-box" @bind-Value="Input.BodyTemplate" />
                <label class="form-label mt-3">@UiText.T("PriceJsonPath")</label>
                <InputText class="form-control" @bind-Value="Input.PriceJsonPath" />
                <label class="form-label mt-3">@UiText.T("CurrencyJsonPath")</label>
                <InputText class="form-control" @bind-Value="Input.CurrencyJsonPath" />
                <label class="form-label mt-3">@UiText.T("BookingUrlJsonPath")</label>
                <InputText class="form-control" @bind-Value="Input.UrlJsonPath" />
            </section>
        </div>

        <div class="form-check mt-3">
            <InputCheckbox class="form-check-input" @bind-Value="Input.Enabled" />
            <label class="form-check-label">@UiText.T("Enabled")</label>
        </div>
        <button type="submit" class="btn btn-primary mt-3">@UiText.T("Save")</button>
    </section>
</EditForm>

@code {
    private readonly System.Text.Json.JsonSerializerOptions jsonOptions = new(System.Text.Json.JsonSerializerDefaults.Web) { WriteIndented = true };
    private string? message;

    [SupplyParameterFromForm]
    private FlightProviderForm Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= await LoadInputAsync();
    }

    private async Task<FlightProviderForm> LoadInputAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings.AsNoTracking()
            .FirstAsync(item => item.Kind == IntegrationKind.FlightProvider);
        var options = System.Text.Json.JsonSerializer.Deserialize<FlightProviderOptions>(setting.SettingsJson, jsonOptions) ?? new();
        return FlightProviderForm.FromOptions(options, setting.Enabled);
    }

    private async Task SaveAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings.FirstAsync(item => item.Kind == IntegrationKind.FlightProvider);
        setting.Enabled = Input.Enabled;
        setting.SettingsJson = System.Text.Json.JsonSerializer.Serialize(Input.ToOptions(), jsonOptions);
        setting.UpdatedAt = DateTimeOffset.UtcNow;
        await db.SaveChangesAsync();
        message = UiText.T("FlightProviderSaved");
    }

    public sealed class FlightProviderForm
    {
        public bool Enabled { get; set; }
        public string ProviderType { get; set; } = "Amadeus";
        public string EndpointUrl { get; set; } = "";
        public string HttpMethod { get; set; } = "POST";
        public string HeadersJson { get; set; } = "{}";
        public string BodyTemplate { get; set; } = "";
        public string PriceJsonPath { get; set; } = "$.offers[0].price";
        public string CurrencyJsonPath { get; set; } = "$.offers[0].currency";
        public string UrlJsonPath { get; set; } = "$.offers[0].url";
        public string AmadeusEnvironment { get; set; } = "Test";
        public string AmadeusClientId { get; set; } = "";
        public string AmadeusClientSecret { get; set; } = "";
        public int AmadeusMaxOffers { get; set; } = 20;

        public static FlightProviderForm FromOptions(FlightProviderOptions options, bool enabled) => new()
        {
            Enabled = enabled,
            ProviderType = options.ProviderType,
            EndpointUrl = options.EndpointUrl,
            HttpMethod = options.HttpMethod,
            HeadersJson = options.HeadersJson,
            BodyTemplate = options.BodyTemplate,
            PriceJsonPath = options.PriceJsonPath,
            CurrencyJsonPath = options.CurrencyJsonPath,
            UrlJsonPath = options.UrlJsonPath,
            AmadeusEnvironment = options.AmadeusEnvironment,
            AmadeusClientId = options.AmadeusClientId,
            AmadeusClientSecret = options.AmadeusClientSecret,
            AmadeusMaxOffers = options.AmadeusMaxOffers
        };

        public FlightProviderOptions ToOptions() => new()
        {
            ProviderType = ProviderType,
            EndpointUrl = EndpointUrl,
            HttpMethod = HttpMethod,
            HeadersJson = HeadersJson,
            BodyTemplate = BodyTemplate,
            PriceJsonPath = PriceJsonPath,
            CurrencyJsonPath = CurrencyJsonPath,
            UrlJsonPath = UrlJsonPath,
            AmadeusEnvironment = AmadeusEnvironment,
            AmadeusClientId = AmadeusClientId,
            AmadeusClientSecret = AmadeusClientSecret,
            AmadeusMaxOffers = Math.Clamp(AmadeusMaxOffers, 1, 50)
        };
    }
}
