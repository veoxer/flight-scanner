@page "/admin/integrations"
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Integrations</PageTitle>

<h1>Flight integrations</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}

<EditForm Model="formModel" FormName="flight-provider-settings">
    <section class="tool-surface">
        <h2>Flight provider API</h2>
        <p class="settings-note">Use Amadeus Self-Service for real flight-offer data, or switch to a custom HTTP provider. The local estimate engine remains available when this is disabled.</p>

        <label class="form-label">Provider</label>
        <InputSelect class="form-select" @bind-Value="flight.ProviderType">
            <option value="Amadeus">Amadeus Flight Offers</option>
            <option value="Custom">Custom HTTP API</option>
        </InputSelect>

        @if (flight.ProviderType.Equals("Amadeus", StringComparison.OrdinalIgnoreCase))
        {
            <label class="form-label mt-3">Environment</label>
            <InputSelect class="form-select" @bind-Value="flight.AmadeusEnvironment">
                <option value="Test">Test - free cached data</option>
                <option value="Production">Production - real-time data</option>
            </InputSelect>
            <label class="form-label mt-3">API Key</label>
            <InputText class="form-control" @bind-Value="flight.AmadeusClientId" />
            <label class="form-label mt-3">API Secret</label>
            <InputText class="form-control" type="password" @bind-Value="flight.AmadeusClientSecret" />
            <label class="form-label mt-3">Max offers</label>
            <InputNumber class="form-control" @bind-Value="flight.AmadeusMaxOffers" />
        }
        else
        {
        <label class="form-label">Endpoint URL</label>
        <InputText class="form-control" @bind-Value="flight.EndpointUrl" />
        <label class="form-label mt-3">HTTP method</label>
        <InputText class="form-control" @bind-Value="flight.HttpMethod" />
        <label class="form-label mt-3">Headers JSON</label>
        <InputTextArea class="form-control code-box" @bind-Value="flight.HeadersJson" />
        <label class="form-label mt-3">Body template</label>
        <InputTextArea class="form-control code-box" @bind-Value="flight.BodyTemplate" />
        <label class="form-label mt-3">Price JSON path</label>
        <InputText class="form-control" @bind-Value="flight.PriceJsonPath" />
        <label class="form-label mt-3">Currency JSON path</label>
        <InputText class="form-control" @bind-Value="flight.CurrencyJsonPath" />
        <label class="form-label mt-3">Booking URL JSON path</label>
        <InputText class="form-control" @bind-Value="flight.UrlJsonPath" />
        }

        <div class="form-check mt-3">
            <InputCheckbox class="form-check-input" @bind-Value="flightEnabled" />
            <label class="form-check-label">Enabled</label>
        </div>
        <button type="button" class="btn btn-primary mt-3" @onclick="SaveAsync">Save</button>
    </section>
</EditForm>

@code {
    private readonly System.Text.Json.JsonSerializerOptions jsonOptions = new(System.Text.Json.JsonSerializerDefaults.Web) { WriteIndented = true };
    private readonly object formModel = new();
    private FlightProviderOptions flight = new();
    private bool flightEnabled;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings.AsNoTracking()
            .FirstAsync(item => item.Kind == IntegrationKind.FlightProvider);
        flight = System.Text.Json.JsonSerializer.Deserialize<FlightProviderOptions>(setting.SettingsJson, jsonOptions) ?? new();
        flightEnabled = setting.Enabled;
    }

    private async Task SaveAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings.FirstAsync(item => item.Kind == IntegrationKind.FlightProvider);
        setting.Enabled = flightEnabled;
        setting.SettingsJson = System.Text.Json.JsonSerializer.Serialize(flight, jsonOptions);
        setting.UpdatedAt = DateTimeOffset.UtcNow;
        await db.SaveChangesAsync();
        message = "Flight provider settings saved.";
    }
}
