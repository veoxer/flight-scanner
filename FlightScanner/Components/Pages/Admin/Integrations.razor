@page "/admin/integrations"
@attribute [Authorize(Roles = "Admin")]
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>@UiText.T("FlightIntegrations")</PageTitle>

<h1>@UiText.T("FlightIntegrations")</h1>

@if (saved)
{
    <div class="alert alert-success">@UiText.T("FlightProviderSaved")</div>
}

<section class="tool-surface">
    <h2>@UiText.T("FlightProviderApi")</h2>
    <p class="settings-note">@UiText.T("FlightProviderText")</p>

    <form method="post" action="/admin/integrations/save">
        <div class="form-check mb-3">
            <input id="serpapi-enabled" class="form-check-input" type="checkbox" name="enabled" value="true" checked="@Input.Enabled" />
            <label class="form-check-label" for="serpapi-enabled">@UiText.T("Enabled")</label>
        </div>

        <label class="form-label" for="serpapi-keys">@UiText.T("ApiKeys")</label>
        <textarea id="serpapi-keys"
                  class="form-control secret-textarea"
                  name="apiKeys"
                  rows="5"
                  autocomplete="off"
                  spellcheck="false">@Input.ApiKeys</textarea>
        <div class="form-text">@UiText.T("ApiKeysHelp")</div>

        <label class="form-label mt-3" for="alert-scan-interval">@UiText.T("AlertScanInterval")</label>
        <input id="alert-scan-interval"
               class="form-control"
               type="number"
               name="alertScanIntervalMinutes"
               value="@Input.AlertScanIntervalMinutes"
               min="@AlertScanOptions.MinIntervalMinutes"
               max="@AlertScanOptions.MaxIntervalMinutes"
               step="15" />
        <div class="form-text">@UiText.T("AlertScanIntervalHelp")</div>

        <button type="submit" class="btn btn-primary mt-3">@UiText.T("Save")</button>
    </form>
</section>

@code {
    private IntegrationForm Input { get; set; } = new();
    private bool saved;

    [Parameter, SupplyParameterFromQuery(Name = "saved")]
    public bool Saved { get; set; }

    protected override async Task OnInitializedAsync()
    {
        saved = Saved;
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings.AsNoTracking()
            .FirstOrDefaultAsync(item => item.Kind == IntegrationKind.FlightProvider);
        if (setting is null)
        {
            return;
        }

        var options = System.Text.Json.JsonSerializer.Deserialize<FlightProviderOptions>(
            setting.SettingsJson,
            new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)) ?? new();
        Input = new IntegrationForm
        {
            Enabled = setting.Enabled,
            ApiKeys = string.IsNullOrWhiteSpace(options.SerpApiApiKeys)
                ? options.SerpApiApiKey
                : options.SerpApiApiKeys,
            AlertScanIntervalMinutes = AlertScanOptions.NormalizeMinutes(options.AlertScanIntervalMinutes)
        };
    }

    private sealed class IntegrationForm
    {
        public bool Enabled { get; set; }
        public string ApiKeys { get; set; } = "";
        public int AlertScanIntervalMinutes { get; set; } = AlertScanOptions.DefaultIntervalMinutes;
    }
}
