@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using System.Text.Json
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager

<PageTitle>@UiText.T("Users")</PageTitle>

<h1>@UiText.T("Users")</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

<EditForm Model="newUser" FormName="admin-create-user" class="tool-surface mb-4">
    <h2>@UiText.T("AddUser")</h2>
    <div class="search-grid">
        <div>
            <label class="form-label">@UiText.T("DisplayName")</label>
            <InputText class="form-control" @bind-Value="newUser.DisplayName" />
        </div>
        <div>
            <label class="form-label">@UiText.T("Email")</label>
            <InputText class="form-control" type="email" @bind-Value="newUser.Email" />
        </div>
        <div>
            <label class="form-label">@UiText.T("TemporaryPassword")</label>
            <InputText class="form-control" type="password" @bind-Value="newUser.Password" />
        </div>
        <div class="form-check align-self-end">
            <InputCheckbox class="form-check-input" @bind-Value="newUser.Admin" />
            <label class="form-check-label">@UiText.T("Admin")</label>
        </div>
    </div>
    <button type="button" class="btn btn-primary mt-3" @onclick="CreateUserAsync">@UiText.T("CreateUser")</button>
</EditForm>

<EditForm Model="alertPolicy" FormName="admin-alert-policy" class="tool-surface mb-4">
    <h2>@UiText.T("AlertLimits")</h2>
    <p class="settings-note">@UiText.T("AlertLimitsText")</p>
    <div class="search-grid">
        <div>
            <label class="form-label">@UiText.T("MaxAlertsPerUser")</label>
            <InputNumber class="form-control" @bind-Value="alertPolicy.MaxAlertsPerUser" min="0" />
        </div>
        <div>
            <label class="form-label">@UiText.T("MaxFlexibleAlertsPerUser")</label>
            <InputNumber class="form-control" @bind-Value="alertPolicy.MaxFlexibleAlertsPerUser" min="0" />
        </div>
        <div>
            <label class="form-label">@UiText.T("MaxSpecificAlertsPerUser")</label>
            <InputNumber class="form-control" @bind-Value="alertPolicy.MaxSpecificAlertsPerUser" min="0" />
        </div>
    </div>
    <button type="button" class="btn btn-primary mt-3" @onclick="SaveAlertPolicyAsync">@UiText.T("SaveAlertLimits")</button>
</EditForm>

<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@UiText.T("User")</th>
                <th>@UiText.T("Email")</th>
                <th>@UiText.T("Roles")</th>
                <th>@UiText.T("Status")</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in rows)
            {
                <tr>
                    <td>@(row.User.DisplayName ?? row.User.UserName)</td>
                    <td>@row.User.Email</td>
                    <td>@string.Join(", ", row.Roles)</td>
                    <td>@(row.User.LockoutEnd > DateTimeOffset.UtcNow ? UiText.T("Locked") : UiText.T("Active"))</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleAdminAsync(row.User)">@(row.Roles.Contains("Admin") ? UiText.T("RemoveAdmin") : UiText.T("MakeAdmin"))</button>
                        <button class="btn btn-sm btn-outline-warning ms-2" @onclick="() => ToggleLockAsync(row.User)">@(row.User.LockoutEnd > DateTimeOffset.UtcNow ? UiText.T("Unlock") : UiText.T("Lock"))</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private readonly JsonSerializerOptions jsonOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };
    private readonly NewUserInput newUser = new();
    private AlertPolicyOptions alertPolicy = new();
    private List<UserRow> rows = [];
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        rows = [];
        try
        {
            foreach (var user in UserManager.Users.OrderBy(user => user.Email).ToList())
            {
                rows.Add(new UserRow(user, await UserManager.GetRolesAsync(user)));
            }

            await LoadAlertPolicyAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task CreateUserAsync()
    {
        message = null;
        var user = new ApplicationUser
        {
            UserName = newUser.Email,
            Email = newUser.Email,
            DisplayName = newUser.DisplayName,
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, newUser.Password);
        if (!result.Succeeded)
        {
            message = string.Join(" ", result.Errors.Select(error => error.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, "User");
        if (newUser.Admin)
        {
            await UserManager.AddToRoleAsync(user, "Admin");
        }

        newUser.DisplayName = "";
        newUser.Email = "";
        newUser.Password = "";
        newUser.Admin = false;
        message = UiText.T("UserCreated");
        await LoadAsync();
    }

    private async Task ToggleAdminAsync(ApplicationUser user)
    {
        if (await UserManager.IsInRoleAsync(user, "Admin"))
        {
            await UserManager.RemoveFromRoleAsync(user, "Admin");
        }
        else
        {
            await UserManager.AddToRoleAsync(user, "Admin");
        }

        await LoadAsync();
    }

    private async Task ToggleLockAsync(ApplicationUser user)
    {
        if (user.LockoutEnd > DateTimeOffset.UtcNow)
        {
            await UserManager.SetLockoutEndDateAsync(user, null);
        }
        else
        {
            await UserManager.SetLockoutEnabledAsync(user, true);
            await UserManager.SetLockoutEndDateAsync(user, DateTimeOffset.UtcNow.AddYears(100));
        }

        await LoadAsync();
    }

    private async Task LoadAlertPolicyAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings
            .AsNoTracking()
            .FirstOrDefaultAsync(item => item.Kind == IntegrationKind.AlertPolicy);
        alertPolicy = setting is null
            ? new AlertPolicyOptions()
            : JsonSerializer.Deserialize<AlertPolicyOptions>(setting.SettingsJson, jsonOptions) ?? new AlertPolicyOptions();
    }

    private async Task SaveAlertPolicyAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings.FirstOrDefaultAsync(item => item.Kind == IntegrationKind.AlertPolicy);
        if (setting is null)
        {
            setting = new IntegrationSetting { Kind = IntegrationKind.AlertPolicy, Enabled = true };
            db.IntegrationSettings.Add(setting);
        }

        alertPolicy.MaxAlertsPerUser = Math.Max(0, alertPolicy.MaxAlertsPerUser);
        alertPolicy.MaxFlexibleAlertsPerUser = Math.Max(0, alertPolicy.MaxFlexibleAlertsPerUser);
        alertPolicy.MaxSpecificAlertsPerUser = Math.Max(0, alertPolicy.MaxSpecificAlertsPerUser);

        setting.Enabled = true;
        setting.SettingsJson = JsonSerializer.Serialize(alertPolicy, jsonOptions);
        setting.UpdatedAt = DateTimeOffset.UtcNow;
        await db.SaveChangesAsync();
        message = UiText.T("AlertLimitsSaved");
    }

    private sealed class NewUserInput
    {
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public bool Admin { get; set; }
    }

    private sealed record UserRow(ApplicationUser User, IList<string> Roles);
}
