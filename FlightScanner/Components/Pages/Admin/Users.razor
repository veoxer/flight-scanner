@page "/admin/users"
@page "/admin/management"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = "Admin")]
@using System.Net.Mail
@using System.Text.Json
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject IConfiguration Configuration

<PageTitle>@UiText.T("Management")</PageTitle>

<h1>@UiText.T("Management")</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(messageIsError ? "alert-danger" : "alert-info")">@message</div>
}

<EditForm EditContext="emailEditContext" FormName="admin-smtp-settings" OnSubmit="SaveEmailSettingsAsync" class="tool-surface mb-4" novalidate>
    <DataAnnotationsValidator />
    <h2>@UiText.T("SmtpSettings")</h2>
    <p class="settings-note">@UiText.T("SmtpSettingsText")</p>
    <div class="search-grid">
        <div>
            <label class="form-label">@UiText.T("SmtpHost")</label>
            <InputText class="@FieldClass(emailValidationRequested && string.IsNullOrWhiteSpace(email.SmtpHost))" @bind-Value="email.SmtpHost" required />
        </div>
        <div>
            <label class="form-label">@UiText.T("SmtpPort")</label>
            <InputNumber class="form-control" @bind-Value="email.SmtpPort" min="1" max="65535" />
        </div>
        <div>
            <label class="form-label">@UiText.T("FromAddress")</label>
            <InputText class="@FieldClass(emailValidationRequested && !IsValidEmailAddress(email.FromAddress))" type="email" @bind-Value="email.FromAddress" required />
        </div>
        <div>
            <label class="form-label">@UiText.T("Username")</label>
            <InputText class="form-control" @bind-Value="email.UserName" />
        </div>
        <div>
            <label class="form-label">@UiText.T("PasswordOrAppPassword")</label>
            <InputText class="form-control" type="password" @bind-Value="email.Password" />
        </div>
        <div class="form-check align-self-end">
            <InputCheckbox class="form-check-input" @bind-Value="email.UseStartTls" />
            <label class="form-check-label">@UiText.T("UseTls")</label>
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-3">@UiText.T("SaveSmtpSettings")</button>
</EditForm>

<EditForm Model="newUser" FormName="admin-create-user" class="tool-surface mb-4">
    <h2>@UiText.T("AddUser")</h2>
    <div class="search-grid">
        <div>
            <label class="form-label">@UiText.T("DisplayName")</label>
            <InputText class="form-control" @bind-Value="newUser.DisplayName" />
        </div>
        <div>
            <label class="form-label">@UiText.T("Email")</label>
            <InputText class="form-control" type="email" @bind-Value="newUser.Email" />
        </div>
        <div>
            <label class="form-label">@UiText.T("TemporaryPassword")</label>
            <InputText class="form-control" type="password" @bind-Value="newUser.Password" />
        </div>
        <div class="form-check align-self-end">
            <InputCheckbox class="form-check-input" @bind-Value="newUser.Admin" />
            <label class="form-check-label">@UiText.T("Admin")</label>
        </div>
    </div>
    <button type="button" class="btn btn-primary mt-3" @onclick="CreateUserAsync">@UiText.T("CreateUser")</button>
</EditForm>

<EditForm EditContext="alertPolicyEditContext" FormName="admin-alert-policy" OnSubmit="SaveAlertPolicyAsync" class="tool-surface mb-4" novalidate>
    <DataAnnotationsValidator />
    <h2>@UiText.T("AlertLimits")</h2>
    <p class="settings-note">@UiText.T("AlertLimitsText")</p>
    <div class="search-grid">
        <div>
            <label class="form-label">@UiText.T("MaxAlertsPerUser")</label>
            <InputNumber class="@FieldClass(alertPolicyValidationRequested && alertPolicy.MaxAlertsPerUser < 0)" @bind-Value="alertPolicy.MaxAlertsPerUser" min="0" />
        </div>
        <div>
            <label class="form-label">@UiText.T("MaxFlexibleAlertsPerUser")</label>
            <InputNumber class="@FieldClass(alertPolicyValidationRequested && alertPolicy.MaxFlexibleAlertsPerUser < 0)" @bind-Value="alertPolicy.MaxFlexibleAlertsPerUser" min="0" />
        </div>
        <div>
            <label class="form-label">@UiText.T("MaxSpecificAlertsPerUser")</label>
            <InputNumber class="@FieldClass(alertPolicyValidationRequested && alertPolicy.MaxSpecificAlertsPerUser < 0)" @bind-Value="alertPolicy.MaxSpecificAlertsPerUser" min="0" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-3">@UiText.T("SaveAlertLimits")</button>
</EditForm>

<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@UiText.T("User")</th>
                <th>@UiText.T("Email")</th>
                <th>@UiText.T("Roles")</th>
                <th>@UiText.T("Status")</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in rows)
            {
                <tr>
                    <td>@(row.User.DisplayName ?? row.User.UserName)</td>
                    <td>@row.User.Email</td>
                    <td>@string.Join(", ", row.Roles)</td>
                    <td>@(row.User.LockoutEnd > DateTimeOffset.UtcNow ? UiText.T("Locked") : UiText.T("Active"))</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleAdminAsync(row.User)">@(row.Roles.Contains("Admin") ? UiText.T("RemoveAdmin") : UiText.T("MakeAdmin"))</button>
                        <button class="btn btn-sm btn-outline-warning ms-2" @onclick="() => ToggleLockAsync(row.User)">@(row.User.LockoutEnd > DateTimeOffset.UtcNow ? UiText.T("Unlock") : UiText.T("Lock"))</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private readonly JsonSerializerOptions jsonOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };
    private readonly NewUserInput newUser = new();
    private EmailOptions email = new();
    private AlertPolicyOptions alertPolicy = new();
    private EditContext emailEditContext = default!;
    private EditContext alertPolicyEditContext = default!;
    private List<UserRow> rows = [];
    private string? message;
    private bool messageIsError;
    private bool emailValidationRequested;
    private bool alertPolicyValidationRequested;

    protected override async Task OnInitializedAsync()
    {
        emailEditContext = new EditContext(email);
        alertPolicyEditContext = new EditContext(alertPolicy);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        rows = [];
        try
        {
            foreach (var user in UserManager.Users.OrderBy(user => user.Email).ToList())
            {
                rows.Add(new UserRow(user, await UserManager.GetRolesAsync(user)));
            }

            await LoadAlertPolicyAsync();
            await LoadEmailSettingsAsync();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, isError: true);
        }
    }

    private async Task CreateUserAsync()
    {
        SetMessage(null);
        if (string.IsNullOrWhiteSpace(newUser.DisplayName))
        {
            SetMessage(string.Format(UiText.T("FieldRequired"), UiText.T("DisplayName")), isError: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(newUser.Email))
        {
            SetMessage(string.Format(UiText.T("FieldRequired"), UiText.T("Email")), isError: true);
            return;
        }

        if (!IsValidEmailAddress(newUser.Email))
        {
            SetMessage(string.Format(UiText.T("EmailAddressInvalid"), UiText.T("Email")), isError: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(newUser.Password))
        {
            SetMessage(string.Format(UiText.T("FieldRequired"), UiText.T("TemporaryPassword")), isError: true);
            return;
        }

        var user = new ApplicationUser
        {
            UserName = newUser.Email,
            Email = newUser.Email,
            DisplayName = newUser.DisplayName,
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, newUser.Password);
        if (!result.Succeeded)
        {
            SetMessage(string.Join(" ", result.Errors.Select(error => error.Description)), isError: true);
            return;
        }

        await UserManager.AddToRoleAsync(user, "User");
        if (newUser.Admin)
        {
            await UserManager.AddToRoleAsync(user, "Admin");
        }

        newUser.DisplayName = "";
        newUser.Email = "";
        newUser.Password = "";
        newUser.Admin = false;
        SetMessage(UiText.T("UserCreated"));
        await LoadAsync();
    }

    private async Task ToggleAdminAsync(ApplicationUser user)
    {
        if (await UserManager.IsInRoleAsync(user, "Admin"))
        {
            await UserManager.RemoveFromRoleAsync(user, "Admin");
        }
        else
        {
            await UserManager.AddToRoleAsync(user, "Admin");
        }

        await LoadAsync();
    }

    private async Task ToggleLockAsync(ApplicationUser user)
    {
        if (user.LockoutEnd > DateTimeOffset.UtcNow)
        {
            await UserManager.SetLockoutEndDateAsync(user, null);
        }
        else
        {
            await UserManager.SetLockoutEnabledAsync(user, true);
            await UserManager.SetLockoutEndDateAsync(user, DateTimeOffset.UtcNow.AddYears(100));
        }

        await LoadAsync();
    }

    private async Task LoadEmailSettingsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings
            .AsNoTracking()
            .FirstOrDefaultAsync(item => item.Kind == IntegrationKind.Email);
        email = EmailOptionsResolver.MergeWithConfigurationFallback(setting?.SettingsJson, Configuration);
        emailEditContext = new EditContext(email);
    }

    private async Task SaveEmailSettingsAsync(EditContext editContext)
    {
        emailValidationRequested = true;
        SetMessage(null);
        editContext.Validate();
        if (editContext.GetValidationMessages().Any())
        {
            SetMessage(UiText.T("FixHighlightedFields"), isError: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(email.SmtpHost))
        {
            SetMessage(string.Format(UiText.T("FieldRequired"), UiText.T("SmtpHost")), isError: true);
            return;
        }

        if (!IsValidEmailAddress(email.FromAddress))
        {
            SetMessage(string.Format(UiText.T("EmailAddressInvalid"), UiText.T("FromAddress")), isError: true);
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var setting = await db.IntegrationSettings.FirstOrDefaultAsync(item => item.Kind == IntegrationKind.Email);
            if (setting is null)
            {
                setting = new IntegrationSetting { Kind = IntegrationKind.Email, Enabled = false };
                db.IntegrationSettings.Add(setting);
            }

            email.SmtpHost = email.SmtpHost.Trim();
            email.FromAddress = email.FromAddress.Trim();
            email.UserName = email.UserName.Trim();
            email.Password = email.Password.Trim();
            email.SmtpPort = Math.Clamp(email.SmtpPort, 1, 65535);

            setting.SettingsJson = JsonSerializer.Serialize(email, jsonOptions);
            setting.UpdatedAt = DateTimeOffset.UtcNow;
            await db.SaveChangesAsync();
            emailValidationRequested = false;
            SetMessage(UiText.T("SmtpSettingsSaved"));
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, isError: true);
        }
    }

    private async Task LoadAlertPolicyAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var setting = await db.IntegrationSettings
            .AsNoTracking()
            .FirstOrDefaultAsync(item => item.Kind == IntegrationKind.AlertPolicy);
        alertPolicy = setting is null
            ? new AlertPolicyOptions()
            : JsonSerializer.Deserialize<AlertPolicyOptions>(setting.SettingsJson, jsonOptions) ?? new AlertPolicyOptions();
        alertPolicyEditContext = new EditContext(alertPolicy);
    }

    private async Task SaveAlertPolicyAsync(EditContext editContext)
    {
        alertPolicyValidationRequested = true;
        SetMessage(null);
        editContext.Validate();
        if (editContext.GetValidationMessages().Any() ||
            alertPolicy.MaxAlertsPerUser < 0 ||
            alertPolicy.MaxFlexibleAlertsPerUser < 0 ||
            alertPolicy.MaxSpecificAlertsPerUser < 0)
        {
            SetMessage(UiText.T("FixHighlightedFields"), isError: true);
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var setting = await db.IntegrationSettings.FirstOrDefaultAsync(item => item.Kind == IntegrationKind.AlertPolicy);
            if (setting is null)
            {
                setting = new IntegrationSetting { Kind = IntegrationKind.AlertPolicy, Enabled = true };
                db.IntegrationSettings.Add(setting);
            }

            alertPolicy.MaxAlertsPerUser = Math.Max(0, alertPolicy.MaxAlertsPerUser);
            alertPolicy.MaxFlexibleAlertsPerUser = Math.Max(0, alertPolicy.MaxFlexibleAlertsPerUser);
            alertPolicy.MaxSpecificAlertsPerUser = Math.Max(0, alertPolicy.MaxSpecificAlertsPerUser);

            setting.Enabled = true;
            setting.SettingsJson = JsonSerializer.Serialize(alertPolicy, jsonOptions);
            setting.UpdatedAt = DateTimeOffset.UtcNow;
            await db.SaveChangesAsync();
            alertPolicyValidationRequested = false;
            SetMessage(UiText.T("AlertLimitsSaved"));
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, isError: true);
        }
    }

    private void SetMessage(string? value, bool isError = false)
    {
        message = value;
        messageIsError = isError;
    }

    private static string FieldClass(bool invalid)
    {
        return invalid ? "form-control is-invalid" : "form-control";
    }

    private static bool IsValidEmailAddress(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        try
        {
            var address = new MailAddress(value);
            return address.Address.Equals(value.Trim(), StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }

    private sealed class NewUserInput
    {
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public bool Admin { get; set; }
    }

    private sealed record UserRow(ApplicationUser User, IList<string> Roles);
}
