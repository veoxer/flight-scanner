@page "/admin/reminders"
@attribute [Authorize(Roles = "Admin")]
@using FlightScanner.Features.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>@UiText.T("ReminderSettings")</PageTitle>

<h1>@UiText.T("ReminderSettings")</h1>

@if (Saved)
{
    <div class="alert alert-success">@UiText.T("ReminderSettingsSaved")</div>
}

<form method="post" action="/admin/reminders/save">
    <section class="tool-surface mb-3">
        <h2>@UiText.T("DeliveryChannels")</h2>
        <p class="settings-note">@UiText.T("DeliveryChannelsText")</p>

        <div class="channel-grid">
            <label class="channel-toggle">
                <input class="form-check-input" type="checkbox" name="emailEnabled" value="true" checked="@emailEnabled" />
                <span>
                    <strong>Email</strong>
                    <small>@UiText.T("SendSmtp")</small>
                </span>
            </label>
            <label class="channel-toggle">
                <input class="form-check-input" type="checkbox" name="whatsAppEnabled" value="true" checked="@whatsAppEnabled" />
                <span>
                    <strong>WhatsApp</strong>
                    <small>@UiText.T("SendWhatsapp")</small>
                </span>
            </label>
            <label class="channel-toggle">
                <input class="form-check-input" type="checkbox" name="webPushEnabled" value="true" checked="@webPushEnabled" />
                <span>
                    <strong>@UiText.T("MobileNotification")</strong>
                    <small>@UiText.T("UseBrowserPush")</small>
                </span>
            </label>
        </div>
    </section>

    <div class="settings-grid">
        <section class="tool-surface">
            <h2>WhatsApp API</h2>
            <label class="form-label">@UiText.T("EndpointUrl")</label>
            <input class="form-control" name="whatsAppEndpointUrl" value="@whatsApp.EndpointUrl" />
            <label class="form-label mt-3">@UiText.T("HttpMethod")</label>
            <input class="form-control" name="whatsAppHttpMethod" value="@whatsApp.HttpMethod" />
            <label class="form-label mt-3">@UiText.T("HeadersJson")</label>
            <textarea class="form-control code-box" name="whatsAppHeadersJson">@whatsApp.HeadersJson</textarea>
            <label class="form-label mt-3">@UiText.T("RecipientPhone")</label>
            <input class="form-control" name="whatsAppTo" value="@whatsApp.To" />
            <input type="hidden" name="whatsAppBodyTemplate" value="@whatsApp.BodyTemplate" />
        </section>

        <section class="tool-surface">
            <h2>@UiText.T("MobileNotification")</h2>
            <label class="form-label">@UiText.T("VapidPublicKey")</label>
            <textarea class="form-control code-box" name="vapidPublicKey">@webPush.PublicKey</textarea>
            <label class="form-label mt-3">@UiText.T("VapidPrivateKey")</label>
            <textarea class="form-control code-box" name="vapidPrivateKey">@webPush.PrivateKey</textarea>
            <label class="form-label mt-3">@UiText.T("Subject")</label>
            <input class="form-control" name="vapidSubject" value="@webPush.Subject" />
        </section>
    </div>

    <button type="submit" class="btn btn-primary mt-3">@UiText.T("SaveReminderSettings")</button>
</form>

@code {
    private readonly System.Text.Json.JsonSerializerOptions jsonOptions = new(System.Text.Json.JsonSerializerDefaults.Web) { WriteIndented = true };
    private WhatsAppOptions whatsApp = new();
    private WebPushOptions webPush = new();
    private bool emailEnabled;
    private bool whatsAppEnabled;
    private bool webPushEnabled;

    [Parameter, SupplyParameterFromQuery(Name = "saved")]
    public bool Saved { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var settings = await db.IntegrationSettings.AsNoTracking().ToListAsync();
        (_, emailEnabled) = Read<EmailOptions>(settings, IntegrationKind.Email);
        (whatsApp, whatsAppEnabled) = Read<WhatsAppOptions>(settings, IntegrationKind.WhatsApp);
        (webPush, webPushEnabled) = Read<WebPushOptions>(settings, IntegrationKind.WebPush);
    }

    private (T Options, bool Enabled) Read<T>(List<IntegrationSetting> settings, IntegrationKind kind) where T : new()
    {
        var setting = settings.FirstOrDefault(item => item.Kind == kind);
        if (setting is null)
        {
            return (new T(), false);
        }

        return (System.Text.Json.JsonSerializer.Deserialize<T>(setting.SettingsJson, jsonOptions) ?? new T(), setting.Enabled);
    }
}
