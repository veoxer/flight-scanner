@page "/search"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@inject IFlightSearchService FlightSearch
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Search</PageTitle>

<section class="search-command">
    <div>
        <p class="eyebrow">Flight deck</p>
        <h1>Search flights</h1>
        <div class="route-preview" aria-label="Current route">
            <span>@Model.Origin</span>
            <span class="route-arrow">-></span>
            <span>@Model.Destination</span>
        </div>
    </div>
    <div class="search-status-panel">
        <span>@Model.DepartDate?.ToString("MMM d, yyyy")</span>
        <strong>@CurrencySymbol(Model.Currency) @Model.Currency.ToUpperInvariant()</strong>
    </div>
</section>

<EditForm Model="Model" FormName="search-form" method="post" OnValidSubmit="RunSearchAsync">
    <DataAnnotationsValidator />
    <div class="tool-surface search-surface">
        <div class="search-grid">
            <div>
                <label class="form-label">From scope</label>
                <InputSelect class="form-select" @bind-Value="Model.OriginType">
                    @foreach (var type in Enum.GetValues<LocationType>())
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
            </div>
            <div>
                <label class="form-label">From</label>
                <InputText class="form-control" list="origin-locations" @bind-Value="Model.Origin" placeholder="JFK, Casablanca, Morocco, Europe" />
                <ValidationMessage For="() => Model.Origin" />
            </div>
            <div>
                <label class="form-label">To scope</label>
                <InputSelect class="form-select" @bind-Value="Model.DestinationType">
                    @foreach (var type in Enum.GetValues<LocationType>())
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
            </div>
            <div>
                <label class="form-label">To</label>
                <InputText class="form-control" list="destination-locations" @bind-Value="Model.Destination" placeholder="CMN, Paris, Japan, Asia" />
                <ValidationMessage For="() => Model.Destination" />
            </div>
            <div>
                <label class="form-label">Depart date</label>
                <InputDate id="depart-date" class="form-control" data-flight-date="depart" min="@TodayIso" @bind-Value="Model.DepartDate" />
                <ValidationMessage For="() => Model.DepartDate" />
            </div>
            <div>
                <label class="form-label">Return date</label>
                <InputDate id="return-date" class="form-control" data-flight-date="return" min="@TodayIso" @bind-Value="Model.ReturnDate" />
                <ValidationMessage For="() => Model.ReturnDate" />
            </div>
            <div>
                <label class="form-label">Adults</label>
                <InputNumber class="form-control" @bind-Value="Model.Adults" />
            </div>
            <div>
                <label class="form-label">Children</label>
                <InputNumber class="form-control" @bind-Value="Model.Children" />
            </div>
            <div>
                <label class="form-label">Infants</label>
                <InputNumber class="form-control" @bind-Value="Model.Infants" />
            </div>
            <div>
                <label class="form-label">Cabin</label>
                <InputSelect class="form-select" @bind-Value="Model.Cabin">
                    @foreach (var cabin in Enum.GetValues<CabinClass>())
                    {
                        <option value="@cabin">@cabin</option>
                    }
                </InputSelect>
            </div>
            <div>
                <label class="form-label">Max stops</label>
                <InputNumber class="form-control" @bind-Value="Model.MaxStops" />
            </div>
            <div>
                <label class="form-label">Checked bags</label>
                <InputNumber class="form-control" @bind-Value="Model.CheckedBags" />
            </div>
            <div>
                <label class="form-label">Currency</label>
                <div class="currency-control">
                    <span class="currency-glyph" aria-hidden="true">@CurrencySymbol(Model.Currency)</span>
                    <InputText class="form-control currency-input" list="currency-options" maxlength="3" @bind-Value="Model.Currency" />
                </div>
                <ValidationMessage For="() => Model.Currency" />
            </div>
            <div class="direct-toggle">
                <InputCheckbox id="direct-only" class="form-check-input" @bind-Value="Model.DirectOnly" />
                <label class="form-check-label" for="direct-only">Direct flights only</label>
            </div>
        </div>

        <div class="actions-row search-actions">
            <button type="submit" class="btn btn-primary btn-search" disabled="@busy">
                <span aria-hidden="true">⌕</span>
                <span>@(busy ? "Searching..." : "Search")</span>
            </button>
            <div class="target-price">
                <label class="form-label">Alert target</label>
                <InputNumber class="form-control" @bind-Value="Model.TargetPrice" />
            </div>
            <button type="button" class="btn btn-outline-primary" @onclick="SaveAlertAsync" disabled="@busy">Save alert</button>
        </div>
    </div>
</EditForm>

<datalist id="origin-locations">
    @foreach (var location in LocationOptions(Model.OriginType))
    {
        <option value="@LocationValue(location)" label="@LocationLabel(location)"></option>
    }
</datalist>

<datalist id="destination-locations">
    @foreach (var location in LocationOptions(Model.DestinationType))
    {
        <option value="@LocationValue(location)" label="@LocationLabel(location)"></option>
    }
</datalist>

<datalist id="currency-options">
    @foreach (var currency in Currencies)
    {
        <option value="@currency.Code" label="@($"{currency.Symbol} {currency.Name}")"></option>
    }
</datalist>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@if (offers.Count > 0)
{
    <div class="section-heading">
        <div>
            <h2>Fare results</h2>
            <p>@offers.Count offer@(offers.Count == 1 ? "" : "s") found for @Model.Origin to @Model.Destination.</p>
        </div>
    </div>
    <div class="results-grid">
        @foreach (var offer in offers)
        {
            <article class="result-card">
                <div>
                    <strong>@offer.Airline @offer.FlightNumber</strong>
                    <span>@offer.Provider</span>
                </div>
                <div>
                    <strong>@CurrencySymbol(offer.Currency) @offer.Price.ToString("0.##") @offer.Currency</strong>
                    <span>@offer.Stops @(offer.Stops == 1 ? "stop" : "stops") · @FormatDuration(offer.Duration)</span>
                </div>
                <div>
                    <strong>@offer.DepartDate.ToString("yyyy-MM-dd")</strong>
                    <span>@offer.Origin to @offer.Destination</span>
                </div>
                <div class="row-actions">
                    @if (!string.IsNullOrWhiteSpace(offer.BookingUrl) && offer.BookingUrl != "#")
                    {
                        <a class="btn btn-sm btn-outline-primary" href="@offer.BookingUrl" target="_blank" rel="noopener">Open</a>
                    }
                </div>
            </article>
        }
    </div>
}

@if (airlineLinks.Count > 0)
{
    <div class="section-heading">
        <div>
            <h2>Airline direct search</h2>
            <p>Regular and low-cost airline booking pages for this route.</p>
        </div>
    </div>
    <div class="airline-grid">
        @foreach (var link in airlineLinks)
        {
            <article class="airline-card">
                <div>
                    <strong>@link.Airline</strong>
                    <span>@link.Region</span>
                </div>
                <span class="carrier-pill">@link.Category</span>
                <a class="btn btn-sm btn-primary" href="@link.SearchUrl" target="_blank" rel="noopener">Search airline</a>
            </article>
        }
    </div>
}

@code {
    [SupplyParameterFromForm]
    private SearchInput? Input { get; set; }

    private SearchInput Model => Input ??= new SearchInput();

    private static readonly IReadOnlyList<CurrencyOption> Currencies =
    [
        new("USD", "$", "US Dollar"),
        new("EUR", "€", "Euro"),
        new("GBP", "£", "British Pound"),
        new("MAD", "د.م.", "Moroccan Dirham"),
        new("CAD", "C$", "Canadian Dollar"),
        new("AUD", "A$", "Australian Dollar"),
        new("JPY", "¥", "Japanese Yen"),
        new("CNY", "¥", "Chinese Yuan"),
        new("AED", "د.إ", "UAE Dirham"),
        new("SAR", "﷼", "Saudi Riyal"),
        new("CHF", "CHF", "Swiss Franc"),
        new("SEK", "kr", "Swedish Krona"),
        new("NOK", "kr", "Norwegian Krone"),
        new("DKK", "kr", "Danish Krone"),
        new("BRL", "R$", "Brazilian Real"),
        new("MXN", "$", "Mexican Peso"),
        new("ZAR", "R", "South African Rand"),
        new("INR", "₹", "Indian Rupee"),
        new("SGD", "S$", "Singapore Dollar"),
        new("NZD", "NZ$", "New Zealand Dollar")
    ];

    private IReadOnlyList<FlightOffer> offers = [];
    private IReadOnlyList<AirlineSearchLink> airlineLinks = [];
    private List<FlightLocation> locations = [];
    private bool busy;
    private string? message;
    private static string TodayIso => DateTime.Today.ToString("yyyy-MM-dd");

    protected override async Task OnInitializedAsync()
    {
        _ = Model;

        await using var db = await DbFactory.CreateDbContextAsync();
        locations = await db.FlightLocations.AsNoTracking()
            .OrderBy(location => location.Type)
            .ThenBy(location => location.Name)
            .ToListAsync();
    }

    private async Task RunSearchAsync()
    {
        if (!Model.ValidateDateRange(out message))
        {
            offers = [];
            airlineLinks = [];
            return;
        }

        busy = true;
        message = "Searching fares and preparing airline links...";
        var query = Model.ToQuery();
        offers = await FlightSearch.SearchAsync(query);
        airlineLinks = FlightSearch.GetAirlineSearchLinks(query);
        message = offers.Count == 0
            ? "No live provider fares returned. Add Amadeus credentials under Admin > Flight API, or use the airline-direct links below."
            : null;
        busy = false;
    }

    private async Task SaveAlertAsync()
    {
        if (!Model.ValidateDateRange(out message))
        {
            return;
        }

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            message = "Login expired. Please sign in again.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        db.PriceAlerts.Add(Model.ToAlert(userId));
        await db.SaveChangesAsync();
        message = "Alert saved. The background scanner will check it automatically.";
    }

    public sealed class SearchInput
    {
        [Required]
        public LocationType OriginType { get; set; } = LocationType.Airport;

        [Required, StringLength(120, MinimumLength = 2)]
        public string Origin { get; set; } = "JFK";

        [Required]
        public LocationType DestinationType { get; set; } = LocationType.Continent;

        [Required, StringLength(120, MinimumLength = 2)]
        public string Destination { get; set; } = "Europe";

        [Required]
        public DateTime? DepartDate { get; set; } = DateTime.Today.AddDays(14);

        public DateTime? ReturnDate { get; set; } = DateTime.Today.AddDays(21);

        [Range(1, 9)]
        public int Adults { get; set; } = 1;

        [Range(0, 9)]
        public int Children { get; set; }

        [Range(0, 9)]
        public int Infants { get; set; }

        public CabinClass Cabin { get; set; }
        public bool DirectOnly { get; set; }

        [Range(0, 4)]
        public int? MaxStops { get; set; } = 1;

        [Range(0, 9)]
        public int CheckedBags { get; set; }

        [Required, StringLength(3, MinimumLength = 3)]
        public string Currency { get; set; } = "USD";

        [Range(1, 999999)]
        public decimal TargetPrice { get; set; } = 400;

        public bool ValidateDateRange(out string? validationMessage)
        {
            validationMessage = null;
            if (DepartDate is null)
            {
                validationMessage = "Pick a depart date.";
                return false;
            }

            if (DepartDate.Value.Date < DateTime.Today)
            {
                validationMessage = "Depart date cannot be earlier than today.";
                return false;
            }

            if (ReturnDate is not null && ReturnDate.Value.Date < DateTime.Today)
            {
                validationMessage = "Return date cannot be earlier than today.";
                return false;
            }

            if (ReturnDate is not null && ReturnDate.Value.Date < DepartDate.Value.Date)
            {
                var picked = ReturnDate.Value.Date;
                DepartDate = picked;
                ReturnDate = null;
            }

            return true;
        }

        public FlightSearchQuery ToQuery()
        {
            var depart = DepartDate?.Date ?? DateTime.Today;
            var returnDate = ReturnDate?.Date;
            var currency = string.IsNullOrWhiteSpace(Currency) ? "USD" : Currency.Trim().ToUpperInvariant();

            return new FlightSearchQuery(
                OriginType,
                Origin.Trim(),
                DestinationType,
                Destination.Trim(),
                DateOnly.FromDateTime(depart),
                DateOnly.FromDateTime(depart),
                returnDate is null ? null : DateOnly.FromDateTime(returnDate.Value),
                returnDate is null ? null : DateOnly.FromDateTime(returnDate.Value),
                Math.Max(1, Adults),
                Math.Max(0, Children),
                Math.Max(0, Infants),
                Cabin,
                DirectOnly,
                MaxStops,
                Math.Max(0, CheckedBags),
                currency);
        }

        public PriceAlert ToAlert(string userId)
        {
            var query = ToQuery();
            return new PriceAlert
            {
                UserId = userId,
                OriginType = query.OriginType,
                Origin = query.Origin,
                DestinationType = query.DestinationType,
                Destination = query.Destination,
                DepartFrom = query.DepartFrom,
                DepartTo = query.DepartTo,
                ReturnFrom = query.ReturnFrom,
                ReturnTo = query.ReturnTo,
                Adults = query.Adults,
                Children = query.Children,
                Infants = query.Infants,
                Cabin = query.Cabin,
                DirectOnly = query.DirectOnly,
                MaxStops = query.MaxStops,
                CheckedBags = query.CheckedBags,
                Currency = query.Currency,
                TargetPrice = TargetPrice
            };
        }
    }

    private IEnumerable<FlightLocation> LocationOptions(LocationType type)
    {
        return locations
            .Where(location => location.Type == type)
            .Take(80);
    }

    private static string LocationValue(FlightLocation location)
    {
        return location.Type == LocationType.Airport ? location.Code : location.Name;
    }

    private static string LocationLabel(FlightLocation location)
    {
        return location.Type == LocationType.Airport
            ? $"{location.Name} ({location.Code}) - {location.CountryName}"
            : $"{location.Name} - {location.Type}";
    }

    private static string CurrencySymbol(string? code)
    {
        return Currencies.FirstOrDefault(currency => currency.Code.Equals(code?.Trim(), StringComparison.OrdinalIgnoreCase))?.Symbol ?? "¤";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration <= TimeSpan.Zero ? "duration unavailable" : $"{(int)duration.TotalHours} h {duration.Minutes} m";
    }

    private sealed record CurrencyOption(string Code, string Symbol, string Name);
}
