    protected override async Task OnParametersSetAsync()
    {
        NormalizeInputDefaults();
        searchIsPending = false;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            locations = await db.FlightLocations.AsNoTracking()
                .OrderBy(location => location.Type)
                .ThenBy(location => location.Name)
                .Take(2000)
                .ToListAsync();
            await LoadAlertPolicyStateAsync(db);

            if (!Run && !SaveAlert)
            {
                return;
            }

            SetMessage(null);

            if (!TryBuildQuery(out var query, out var validationMessage))
            {
                SetMessage(validationMessage, isError: true);
                return;
            }

            NormalizeDisplay(query);
            var executionKey = BuildExecutionKey(SaveAlert ? "save" : "search", query);
            if (!processedExecutionKeys.Add(executionKey))
            {
                return;
            }

            if (SaveAlert)
            {
                searchIsPending = true;
                await SaveAlertAsync(query);
                await LoadAlertPolicyStateAsync(db);
                RestoreCachedSearchResult(query);
                return;
            }

            var searchResultKey = BuildSearchResultKey(query);
            if (TryGetCompletedSearchResult(searchResultKey, out var completedResult))
            {
                offers = completedResult.Offers;
                airlineLinks = completedResult.AirlineLinks;
                return;
            }

            searchIsPending = true;
            var cachedResult = await GetCachedSearchResultAsync(searchResultKey, query);
            offers = cachedResult.Offers;
            airlineLinks = cachedResult.AirlineLinks;

            if (offers.Count == 0)
            {
                SetMessage(T("NoLiveProvider"));
            }
        }
        finally
        {
            searchIsPending = false;
        }
    }

    private async Task<SearchPageCacheEntry> GetCachedSearchResultAsync(string key, FlightSearchQuery query)
    {
        var now = DateTimeOffset.UtcNow;
        if (SearchPageCache.TryGetValue(key, out var existing) &&
            existing.IsValueCreated &&
            existing.Value.IsCompletedSuccessfully)
        {
            var completed = await existing.Value;
            if (now - completed.CreatedAt <= SearchPageCacheDuration)
            {
                return completed;
            }

            SearchPageCache.TryRemove(KeyValuePair.Create(key, existing));
        }

        PruneSearchPageCache(now);
        var created = new Lazy<Task<SearchPageCacheEntry>>(async () =>
        {
            var resultOffers = await FlightSearch.SearchAsync(query);
            var resultAirlineLinks = FlightSearch.GetAirlineSearchLinks(query);
            return new SearchPageCacheEntry(DateTimeOffset.UtcNow, resultOffers, resultAirlineLinks);
        });
        var current = SearchPageCache.GetOrAdd(key, created);

        try
        {
            return await current.Value;
        }
        catch
        {
            SearchPageCache.TryRemove(KeyValuePair.Create(key, current));
            throw;
        }
    }

    private void RestoreCachedSearchResult(FlightSearchQuery query)
    {
        if (TryGetCompletedSearchResult(BuildSearchResultKey(query), out var cachedResult))
        {
            offers = cachedResult.Offers;
            airlineLinks = cachedResult.AirlineLinks;
        }
    }

    private static bool TryGetCompletedSearchResult(string key, out SearchPageCacheEntry entry)
    {
        var now = DateTimeOffset.UtcNow;
        if (SearchPageCache.TryGetValue(key, out var existing) &&
            existing.IsValueCreated &&
            existing.Value.IsCompletedSuccessfully)
        {
            entry = existing.Value.Result;
            if (now - entry.CreatedAt <= SearchPageCacheDuration)
            {
                return true;
            }

            SearchPageCache.TryRemove(KeyValuePair.Create(key, existing));
        }

        entry = default!;
        return false;
    }

    private static void PruneSearchPageCache(DateTimeOffset now)
    {
        if (SearchPageCache.Count <= 64)
        {
            return;
        }

        foreach (var item in SearchPageCache)
        {
            if (!item.Value.IsValueCreated || !item.Value.Value.IsCompletedSuccessfully)
            {
                continue;
            }

            var entry = item.Value.Value.Result;
            if (now - entry.CreatedAt > SearchPageCacheDuration)
            {
                SearchPageCache.TryRemove(item);
            }
        }
    }

    private string BuildExecutionKey(string action, FlightSearchQuery query)
    {
        return string.Join("|",
            action,
            query.OriginType,
            query.Origin,
            query.DestinationType,
            query.Destination,
            query.DepartFrom,
            query.DepartTo,
            query.ReturnFrom,
            query.ReturnTo,
            query.FlexibleDates,
            query.FlexibleYear,
            query.FlexibleMonth,
            query.FlexibleDepartureDay,
            query.FlexibleStayDays,
            query.Adults,
            query.Children,
            query.Infants,
            query.Cabin,
            query.DirectOnly,
            query.MaxStops,
            query.CheckedBags,
            query.OutboundTimeFromHour,
            query.OutboundTimeToHour,
            query.ReturnTimeFromHour,
            query.ReturnTimeToHour,
            query.Currency,
            NormalizeTargetMode(TargetMode),
            TargetPrice,
            NormalizeTargetMode(TargetMode2),
            TargetPrice2);
    }

    private static string BuildSearchResultKey(FlightSearchQuery query)
    {
        return string.Join("|",
            "search-result",
            query.OriginType,
            query.Origin,
            query.DestinationType,
            query.Destination,
            query.DepartFrom,
            query.DepartTo,
            query.ReturnFrom,
            query.ReturnTo,
            query.FlexibleDates,
            query.FlexibleYear,
            query.FlexibleMonth,
            query.FlexibleDepartureDay,
            query.FlexibleStayDays,
            query.Adults,
            query.Children,
            query.Infants,
            query.Cabin,
            query.DirectOnly,
            query.MaxStops,
            query.CheckedBags,
            query.OutboundTimeFromHour,
            query.OutboundTimeToHour,
            query.ReturnTimeFromHour,
            query.ReturnTimeToHour,
            query.Currency);
    }

    private static string BuildAlertSaveKey(string userId, FlightSearchQuery query, decimal? maxTargetPrice, decimal? minTargetPrice)
    {
        return string.Join("|",
            "alert-save",
            userId,
            BuildSearchResultKey(query),
            maxTargetPrice?.ToString("0.##", CultureInfo.InvariantCulture) ?? "",
            minTargetPrice?.ToString("0.##", CultureInfo.InvariantCulture) ?? "");
    }

    private static bool TryEnterAlertSaveGate(string key)
    {
        var now = DateTimeOffset.UtcNow;
        foreach (var item in RecentAlertSaveKeys)
        {
            if (now - item.Value > AlertSaveGateDuration)
            {
                RecentAlertSaveKeys.TryRemove(item.Key, out _);
            }
        }

        return RecentAlertSaveKeys.TryAdd(key, now);
    }

    private async Task SaveAlertAsync(FlightSearchQuery query)
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            SetMessage(T("LoginExpired"), isError: true);
            return;
        }

        if (!TryParseTargetFilters(out var maxTargetPrice, out var minTargetPrice, out var targetMessage))
        {
            SetMessage(targetMessage, isError: true);
            return;
        }

        var alertSaveKey = BuildAlertSaveKey(userId, query, maxTargetPrice, minTargetPrice);
        if (!TryEnterAlertSaveGate(alertSaveKey))
        {
            SetMessage(T("AlertSaved"));
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var duplicateExists = await db.PriceAlerts.AnyAsync(alert =>
                alert.UserId == userId &&
                alert.OriginType == query.OriginType &&
                alert.Origin == query.Origin &&
                alert.DestinationType == query.DestinationType &&
                alert.Destination == query.Destination &&
                alert.DepartFrom == query.DepartFrom &&
                alert.DepartTo == query.DepartTo &&
                alert.ReturnFrom == query.ReturnFrom &&
                alert.ReturnTo == query.ReturnTo &&
                alert.FlexibleDates == query.FlexibleDates &&
                alert.FlexibleYear == query.FlexibleYear &&
                alert.FlexibleMonth == query.FlexibleMonth &&
                alert.FlexibleDepartureDay == query.FlexibleDepartureDay &&
                alert.FlexibleStayDays == query.FlexibleStayDays &&
                alert.Adults == query.Adults &&
                alert.Children == query.Children &&
                alert.Infants == query.Infants &&
                alert.Cabin == query.Cabin &&
                alert.DirectOnly == query.DirectOnly &&
                alert.MaxStops == query.MaxStops &&
                alert.CheckedBags == query.CheckedBags &&
                alert.OutboundTimeFromHour == query.OutboundTimeFromHour &&
                alert.OutboundTimeToHour == query.OutboundTimeToHour &&
                alert.ReturnTimeFromHour == query.ReturnTimeFromHour &&
                alert.ReturnTimeToHour == query.ReturnTimeToHour &&
                alert.Currency == query.Currency &&
                alert.MaxTargetPrice == maxTargetPrice &&
                alert.MinTargetPrice == minTargetPrice);

            if (duplicateExists)
            {
                RecentAlertSaveKeys.TryRemove(alertSaveKey, out _);
                SetMessage(T("AlertAlreadySaved"), isError: true);
                return;
            }

            var policyMessage = await ValidateAlertPolicyAsync(db, userId, query.FlexibleDates);
            if (!string.IsNullOrWhiteSpace(policyMessage))
            {
                RecentAlertSaveKeys.TryRemove(alertSaveKey, out _);
                SetMessage(policyMessage, isError: true);
                return;
            }

            db.PriceAlerts.Add(new PriceAlert
            {
                UserId = userId,
                OriginType = query.OriginType,
                Origin = query.Origin,
                DestinationType = query.DestinationType,
                Destination = query.Destination,
                DepartFrom = query.DepartFrom,
                DepartTo = query.DepartTo,
                ReturnFrom = query.ReturnFrom,
                ReturnTo = query.ReturnTo,
                FlexibleDates = query.FlexibleDates,
                FlexibleYear = query.FlexibleYear,
                FlexibleMonth = query.FlexibleMonth,
                FlexibleDepartureDay = query.FlexibleDepartureDay,
                FlexibleStayDays = query.FlexibleStayDays,
                Adults = query.Adults,
                Children = query.Children,
                Infants = query.Infants,
                Cabin = query.Cabin,
                DirectOnly = query.DirectOnly,
                MaxStops = query.MaxStops,
                CheckedBags = query.CheckedBags,
                OutboundTimeFromHour = query.OutboundTimeFromHour,
                OutboundTimeToHour = query.OutboundTimeToHour,
                ReturnTimeFromHour = query.ReturnTimeFromHour,
                ReturnTimeToHour = query.ReturnTimeToHour,
                Currency = query.Currency,
                TargetMode = BuildLegacyTargetMode(maxTargetPrice, minTargetPrice),
                TargetPrice = BuildLegacyTargetPrice(maxTargetPrice, minTargetPrice),
                MaxTargetPrice = maxTargetPrice,
                MinTargetPrice = minTargetPrice
            });
            await db.SaveChangesAsync();
            SetMessage(T("AlertSaved"));
        }
        catch
        {
            RecentAlertSaveKeys.TryRemove(alertSaveKey, out _);
            throw;
        }
    }

    private void SetMessage(string? value, bool isError = false)
    {
        message = value;
        messageIsError = isError;
    }

    private async Task<string?> ValidateAlertPolicyAsync(ApplicationDbContext db, string userId, bool flexibleDates)
    {
        var setting = await db.IntegrationSettings
            .AsNoTracking()
            .FirstOrDefaultAsync(item => item.Kind == IntegrationKind.AlertPolicy);
        var policy = setting is null
            ? new AlertPolicyOptions()
            : System.Text.Json.JsonSerializer.Deserialize<AlertPolicyOptions>(
                setting.SettingsJson,
                new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)) ?? new();

        if (policy.MaxAlertsPerUser <= 0 &&
            policy.MaxFlexibleAlertsPerUser <= 0 &&
            policy.MaxSpecificAlertsPerUser <= 0)
        {
            return null;
        }

        var activeAlerts = await db.PriceAlerts
            .AsNoTracking()
            .Where(alert => alert.UserId == userId && alert.IsActive)
            .Select(alert => alert.FlexibleDates)
            .ToListAsync();

        if (policy.MaxAlertsPerUser > 0 && activeAlerts.Count >= policy.MaxAlertsPerUser)
        {
            return string.Format(CultureInfo.CurrentCulture, T("ActiveAlertLimitReached"), policy.MaxAlertsPerUser);
        }

        if (flexibleDates &&
            policy.MaxFlexibleAlertsPerUser > 0 &&
            activeAlerts.Count(alert => alert) >= policy.MaxFlexibleAlertsPerUser)
        {
            return string.Format(CultureInfo.CurrentCulture, T("ActiveFlexibleAlertLimitReached"), policy.MaxFlexibleAlertsPerUser);
        }

        if (!flexibleDates &&
            policy.MaxSpecificAlertsPerUser > 0 &&
            activeAlerts.Count(alert => !alert) >= policy.MaxSpecificAlertsPerUser)
        {
            return string.Format(CultureInfo.CurrentCulture, T("ActiveSpecificAlertLimitReached"), policy.MaxSpecificAlertsPerUser);
        }

        return null;
    }

    private async Task LoadAlertPolicyStateAsync(ApplicationDbContext db)
    {
        var setting = await db.IntegrationSettings
            .AsNoTracking()
            .FirstOrDefaultAsync(item => item.Kind == IntegrationKind.AlertPolicy);
        alertPolicy = setting is null
            ? new AlertPolicyOptions()
            : System.Text.Json.JsonSerializer.Deserialize<AlertPolicyOptions>(
                setting.SettingsJson,
                new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)) ?? new();

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            activeAlertCount = 0;
            activeFlexibleAlertCount = 0;
            activeSpecificAlertCount = 0;
            return;
        }

        var activeAlerts = await db.PriceAlerts
            .AsNoTracking()
            .Where(alert => alert.UserId == userId && alert.IsActive)
            .Select(alert => alert.FlexibleDates)
            .ToListAsync();
        activeAlertCount = activeAlerts.Count;
        activeFlexibleAlertCount = activeAlerts.Count(alert => alert);
        activeSpecificAlertCount = activeAlerts.Count(alert => !alert);
    }

    private bool TryBuildQuery(out FlightSearchQuery query, out string? validationMessage)
    {
        query = default!;
        validationMessage = null;

        DateOnly departDate;
        DateOnly? returnDate;
        int? flexibleYear = null;
        int? flexibleMonth = null;
        DayOfWeek? flexibleDepartureDay = null;
        int? flexibleStayDays = null;
        if (IsFlexibleDates)
        {
            if (!TryBuildFlexibleDateSeed(out departDate, out returnDate, out flexibleYear, out flexibleMonth, out flexibleDepartureDay, out flexibleStayDays, out validationMessage))
            {
                return false;
            }
        }
        else
        {
            if (!TryParseDate(Depart, out departDate))
            {
                validationMessage = T("DepartDateInvalid");
                return false;
            }

            returnDate = null;
            if (!IsOneWay && !string.IsNullOrWhiteSpace(ReturnDate))
            {
                if (!TryParseDate(ReturnDate, out var parsedReturnDate))
                {
                    validationMessage = T("ReturnDateInvalid");
                    return false;
                }

                returnDate = parsedReturnDate;
            }

            if (returnDate is not null && returnDate.Value < departDate)
            {
                departDate = returnDate.Value;
                returnDate = null;
            }
        }

        if (SaveAlert && !TryParseTargetFilters(out _, out _, out validationMessage))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(Origin))
        {
            validationMessage = T("OriginRequired");
            return false;
        }

        if (string.IsNullOrWhiteSpace(Destination))
        {
            validationMessage = T("DestinationRequired");
            return false;
        }

        if (Adults + Children < 1)
        {
            validationMessage = T("TravellersRequired");
            return false;
        }

        if (!TryResolvePostedLocation(OriginType, Origin, OriginCode, out var originType, out var origin, out validationMessage))
        {
            return false;
        }

        if (!TryResolvePostedLocation(DestinationType, Destination, DestinationCode, out var destinationType, out var destination, out validationMessage))
        {
            return false;
        }

        var currency = string.IsNullOrWhiteSpace(Currency) ? "MAD" : Currency.Trim().ToUpperInvariant();
        var outboundTimeFromHour = ParseTimeHour(OutboundTimeFrom);
        var outboundTimeToHour = ParseTimeHour(OutboundTimeTo);
        var returnTimeFromHour = IsOneWay ? null : ParseTimeHour(ReturnTimeFrom);
        var returnTimeToHour = IsOneWay ? null : ParseTimeHour(ReturnTimeTo);

        query = new FlightSearchQuery(
            originType,
            origin,
            destinationType,
            destination,
            departDate,
            departDate,
            returnDate,
            returnDate,
            IsFlexibleDates,
            flexibleYear,
            flexibleMonth,
            flexibleDepartureDay,
            flexibleStayDays,
            Math.Clamp(Adults, 1, 9),
            Math.Clamp(Children, 0, 9),
            0,
            Cabin,
            DirectOnly,
            MaxStops,
            Math.Max(0, CheckedBags),
            outboundTimeFromHour,
            outboundTimeToHour,
            returnTimeFromHour,
            returnTimeToHour,
            currency);
        return true;
    }

    private void NormalizeDisplay(FlightSearchQuery query)
    {
        OriginType = query.OriginType.ToString();
        DestinationType = query.DestinationType.ToString();
        Depart = query.DepartFrom.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);
        ReturnDate = query.ReturnFrom?.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture) ?? "";
        TripType = query.ReturnFrom is null ? "OneWay" : "Return";
        DateMode = query.FlexibleDates ? "Flexible" : "Specific";
        FlexibleYear = query.FlexibleYear ?? FlexibleYear;
        FlexibleMonth = query.FlexibleMonth ?? FlexibleMonth;
        FlexibleDepartureDay = query.FlexibleDepartureDay?.ToString() ?? FlexibleDepartureDay;
        FlexibleStayDays = query.FlexibleStayDays ?? FlexibleStayDays;
        OutboundTimeFrom = FormatTimeHour(query.OutboundTimeFromHour);
        OutboundTimeTo = FormatTimeHour(query.OutboundTimeToHour);
        ReturnTimeFrom = FormatTimeHour(query.ReturnTimeFromHour);
        ReturnTimeTo = FormatTimeHour(query.ReturnTimeToHour);
        Currency = query.Currency;
        TargetMode = NormalizeTargetMode(TargetMode);
        TargetMode2 = NormalizeTargetMode(TargetMode2);
    }

    private void NormalizeInputDefaults()
    {
        Origin = Origin?.Trim() ?? "";
        Destination = Destination?.Trim() ?? "";
        OriginType = string.IsNullOrWhiteSpace(OriginType) ? nameof(LocationType.Airport) : OriginType;
        DestinationType = string.IsNullOrWhiteSpace(DestinationType) ? nameof(LocationType.Continent) : DestinationType;
        Depart = Depart ?? "";
        ReturnDate = ReturnDate ?? "";
        Adults = Math.Clamp(Adults, 1, 9);
        Children = Math.Clamp(Children, 0, 9);
        OutboundTimeFrom = NormalizeTimeValue(OutboundTimeFrom);
        OutboundTimeTo = NormalizeTimeValue(OutboundTimeTo);
        ReturnTimeFrom = IsOneWay ? "" : NormalizeTimeValue(ReturnTimeFrom);
        ReturnTimeTo = IsOneWay ? "" : NormalizeTimeValue(ReturnTimeTo);
        Currency = string.IsNullOrWhiteSpace(Currency)
            ? "MAD"
            : Currency.Trim().ToUpperInvariant();
        TripType = IsOneWay ? "OneWay" : "Return";
        DateMode = IsFlexibleDates ? "Flexible" : "Specific";
        TargetFilterCount = Math.Clamp(TargetFilterCount, 1, 2);
        NearbyAirports = NearbyAirports || OriginNearby || DestinationNearby;
        var defaultFlexibleDate = DateTime.Today.AddDays(30);
        FlexibleYear ??= defaultFlexibleDate.Year;
        FlexibleMonth = FlexibleMonth is >= 1 and <= 12 ? FlexibleMonth : defaultFlexibleDate.Month;
        FlexibleDepartureDay = ParseFlexibleDepartureDay().ToString();
        FlexibleStayDays = Math.Clamp(FlexibleStayDays, 1, 365);
    }

    private bool TryResolvePostedLocation(
        string typeValue,
        string displayValue,
        string? postedCode,
        out LocationType type,
        out string resolvedValue,
        out string? validationMessage)
    {
        type = default;
        resolvedValue = "";
        validationMessage = null;

        if (string.IsNullOrWhiteSpace(displayValue))
        {
            validationMessage = T("ChooseSuggestedLocation");
            return false;
        }

        if (!Enum.TryParse<LocationType>(typeValue, ignoreCase: true, out type))
        {
            validationMessage = T("ChooseSuggestedLocation");
            return false;
        }

        var code = postedCode?.Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(code))
        {
            validationMessage = T("ChooseSuggestedLocation");
            return false;
        }

        var selectedType = type;
        var match = locations.FirstOrDefault(location =>
            location.Type == selectedType &&
            location.Code.Equals(code, StringComparison.OrdinalIgnoreCase));
        if (match is null)
        {
            validationMessage = T("ChooseSuggestedLocation");
            return false;
        }

        resolvedValue = match.Code;
        return true;
    }

    private FlightLocation? FindBestLocation(string value)
    {
        var query = CleanLocationValue(value);
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        return locations
            .OrderByDescending(location => location.Code.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(location => location.Name.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenBy(location => location.Type)
            .FirstOrDefault(location => MatchesLocation(location, query));
    }

    private static bool MatchesLocation(FlightLocation location, string value)
    {
        return location.Code.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            location.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (location.CountryName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            location.Continent.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static string CleanLocationValue(string value)
    {
        var trimmed = value.Trim();
        var separator = trimmed.IndexOf(" - ", StringComparison.Ordinal);
        return separator > 0 ? trimmed[..separator] : trimmed;
    }

    private static bool TryParseDate(string value, out DateOnly date)
    {
        return DateOnly.TryParseExact(value.Trim(), "dd/MM/yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out date) ||
            DateOnly.TryParseExact(value.Trim(), "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out date);
    }

    private static int? ParseTimeHour(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return TimeOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var time)
            ? Math.Clamp(time.Hour, 0, 23)
            : null;
    }

    private static string FormatTimeHour(int? hour)
    {
        return hour is { } value ? $"{Math.Clamp(value, 0, 23):00}:00" : "";
    }

    private static string NormalizeTimeValue(string? value)
    {
        return FormatTimeHour(ParseTimeHour(value));
    }

    private bool TryBuildFlexibleDateSeed(
        out DateOnly departDate,
        out DateOnly? returnDate,
        out int? flexibleYear,
        out int? flexibleMonth,
        out DayOfWeek? flexibleDepartureDay,
        out int? flexibleStayDays,
        out string? validationMessage)
    {
        departDate = default;
        returnDate = null;
        flexibleYear = null;
        flexibleMonth = null;
        flexibleDepartureDay = null;
        flexibleStayDays = null;
        validationMessage = null;

        if (FlexibleYear is not { } year || year is < 1900 or > 2100 ||
            FlexibleMonth is not { } month || month is < 1 or > 12)
        {
            validationMessage = T("FlexibleDateInvalid");
            return false;
        }

        var departureDay = ParseFlexibleDepartureDay();
        var stayDays = Math.Clamp(FlexibleStayDays, 1, 365);
        var firstDay = new DateOnly(year, month, 1);
        var daysInMonth = DateTime.DaysInMonth(year, month);
        for (var day = 1; day <= daysInMonth; day++)
        {
            var candidate = firstDay.AddDays(day - 1);
            if (candidate.DayOfWeek != departureDay)
            {
                continue;
            }

            departDate = candidate;
            returnDate = IsOneWay ? null : candidate.AddDays(stayDays);
            flexibleYear = year;
            flexibleMonth = month;
            flexibleDepartureDay = departureDay;
            flexibleStayDays = IsOneWay ? null : stayDays;
            return true;
        }

        validationMessage = T("FlexibleDateInvalid");
        return false;
    }

    private DayOfWeek ParseFlexibleDepartureDay()
    {
        return Enum.TryParse<DayOfWeek>(FlexibleDepartureDay, ignoreCase: true, out var day)
            ? day
            : DayOfWeek.Monday;
    }

    private static string CurrencySymbol(string? code)
    {
        return Currencies.FirstOrDefault(currency => currency.Code.Equals(code?.Trim(), StringComparison.OrdinalIgnoreCase))?.Symbol ?? "¤";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration <= TimeSpan.Zero ? T("DurationUnavailable") : $"{(int)duration.TotalHours} h {duration.Minutes} m";
    }

    private static string FormatTime(DateTime? time)
    {
        return time?.ToString("h:mm tt", CultureInfo.CurrentCulture) ?? "--:--";
    }

    private static string FormatDateAttribute(DateOnly? date)
    {
        return date?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? "";
    }

    private static string AirportLabel(FlightAirport airport)
    {
        return string.IsNullOrWhiteSpace(airport.Code) ? airport.Name : $"{airport.Name} ({airport.Code})";
    }

    private static string FormatKilograms(int grams)
    {
        return Math.Max(0, (int)Math.Round(grams / 1000m, MidpointRounding.AwayFromZero)).ToString("N0", CultureInfo.CurrentCulture);
    }

    private static string FormatSignedPercent(int value)
    {
        return value > 0 ? $"+{value}%" : $"{value}%";
    }

    private static string LegTitle(string kind)
    {
        return kind.Equals("Return", StringComparison.OrdinalIgnoreCase) ? T("ReturnFlight") : T("DepartureFlight");
    }

    private static string PriceSubtitle(FlightOffer offer)
    {
        if (offer.ResultKind.Equals("Return", StringComparison.OrdinalIgnoreCase))
        {
            return T("ReturnFlight");
        }

        return offer.ReturnDate is null ? T("OneWay") : T("Return");
    }

    private bool TryParseTargetFilters(out decimal? maxTargetPrice, out decimal? minTargetPrice, out string? validationMessage)
    {
        maxTargetPrice = null;
        minTargetPrice = null;
        validationMessage = null;

        foreach (var (mode, priceText) in new[] { (TargetMode, TargetPrice), (TargetMode2, TargetPrice2) })
        {
            if (string.IsNullOrWhiteSpace(priceText))
            {
                continue;
            }

            if (!decimal.TryParse(priceText, NumberStyles.Number, CultureInfo.InvariantCulture, out var price) || price <= 0)
            {
                validationMessage = T("AlertTargetRequired");
                return false;
            }

            if (NormalizeTargetMode(mode) == "Min")
            {
                minTargetPrice = price;
            }
            else
            {
                maxTargetPrice = price;
            }
        }

        if (maxTargetPrice is null && minTargetPrice is null)
        {
            validationMessage = T("AlertTargetRequired");
            return false;
        }

        if (maxTargetPrice is not null && minTargetPrice is not null && minTargetPrice > maxTargetPrice)
        {
            validationMessage = T("AlertMinGreaterThanMax");
            return false;
        }

        return true;
    }

    private static string BuildLegacyTargetMode(decimal? maxTargetPrice, decimal? minTargetPrice)
    {
        return maxTargetPrice is null && minTargetPrice is not null ? "Min" : "Max";
    }

    private static decimal BuildLegacyTargetPrice(decimal? maxTargetPrice, decimal? minTargetPrice)
    {
        return maxTargetPrice ?? minTargetPrice ?? 0;
    }

    private static string NormalizeTargetMode(string? mode)
    {
        return mode?.Equals("Min", StringComparison.OrdinalIgnoreCase) == true ? "Min" : "Max";
    }

    private static string AirlineLogoUrl(FlightOffer offer)
    {
        if (!string.IsNullOrWhiteSpace(offer.AirlineLogoUrl))
        {
            return offer.AirlineLogoUrl;
        }

        return AirlineLogoUrl(offer.Airline);
    }

    private static string AirlineLogoUrl(string airline)
    {
        var code = AirlineLogoCode(airline);
        return $"https://images.kiwi.com/airlines/64/{Uri.EscapeDataString(code)}.png";
    }

    private static string AirlineLogoCode(string airline)
    {
        var trimmed = airline.Trim();
        if (trimmed.Length is 2 or 3 && trimmed.All(char.IsLetterOrDigit))
        {
            return trimmed.ToUpperInvariant();
        }

        return trimmed.ToLowerInvariant() switch
        {
            "american airlines" => "AA",
            "delta air lines" => "DL",
            "united airlines" => "UA",
            "british airways" => "BA",
            "lufthansa" => "LH",
            "air france" => "AF",
            "klm" => "KL",
            "iberia" => "IB",
            "royal air maroc" => "AT",
            "emirates" => "EK",
            "qatar airways" => "QR",
            "turkish airlines" => "TK",
            "easyjet" => "U2",
            "ryanair" => "FR",
            _ => new string(trimmed.Where(char.IsLetterOrDigit).Take(2).Select(char.ToUpperInvariant).ToArray()).PadRight(2, 'X')
        };
    }

    private static string AirlineInitials(string airline)
    {
        var words = airline.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length >= 2)
        {
            return string.Concat(words.Take(2).Select(word => char.ToUpperInvariant(word[0])));
        }

        return airline.Length >= 2 ? airline[..2].ToUpperInvariant() : airline.ToUpperInvariant();
    }

    private static string CabinLabel(CabinClass cabin)
    {
        return cabin switch
        {
            CabinClass.PremiumEconomy => T("PremiumEconomy"),
            CabinClass.Business => T("Business"),
            CabinClass.First => T("First"),
            _ => T("Economy")
        };
    }

    private static string T(string key) => UiText.T(key);

    private sealed record CurrencyOption(string Code, string Symbol, string Name);
    private sealed record TimeOption(string Value, string Label);
    private sealed record SearchPageCacheEntry(DateTimeOffset CreatedAt, IReadOnlyList<FlightOffer> Offers, IReadOnlyList<AirlineSearchLink> AirlineLinks);
}
