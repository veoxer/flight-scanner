@page "/search"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using FlightScanner.Features.Localization
@inject IFlightSearchService FlightSearch
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@T("Search")</PageTitle>

<section class="flight-hero">
    <div class="trip-mode-row">
        <button type="button" class="trip-mode-button">@T("Return")</button>
    </div>

    <form method="get" action="/search" class="search-native-form" autocomplete="off">
        <input type="hidden" name="run" value="true" />
        <input type="hidden" name="originType" data-location-type="origin" value="@OriginType" />
        <input type="hidden" name="destinationType" data-location-type="destination" value="@DestinationType" />

        <div class="flight-search-bar">
            <div class="travel-field location-field" data-location-box="origin">
                <label for="origin">@T("From")</label>
                <input id="origin" name="origin" class="travel-input location-input" value="@Origin" data-location-input="origin" autocomplete="off" placeholder="@T("CountryCityAirport")" />
                <div class="location-menu" data-location-menu="origin" hidden></div>
            </div>

            <div class="travel-field location-field" data-location-box="destination">
                <label for="destination">@T("To")</label>
                <input id="destination" name="destination" class="travel-input location-input" value="@Destination" data-location-input="destination" autocomplete="off" placeholder="@T("CountryCityAirport")" />
                <div class="location-menu" data-location-menu="destination" hidden></div>
            </div>

            <div class="travel-field compact-field">
                <label for="depart">@T("Depart")</label>
                <div class="date-picker-field">
                    <input id="depart" name="depart" class="travel-input date-text-input" value="@Depart" data-flight-date="depart" inputmode="numeric" autocomplete="off" placeholder="dd/mm/yyyy" />
                    <button type="button" class="date-picker-button" data-date-toggle="depart" aria-label="@T("Depart")">▦</button>
                </div>
            </div>

            <div class="travel-field compact-field">
                <label for="returnDate">@T("Return")</label>
                <div class="date-picker-field">
                    <input id="returnDate" name="returnDate" class="travel-input date-text-input" value="@ReturnDate" data-flight-date="return" inputmode="numeric" autocomplete="off" placeholder="dd/mm/yyyy" />
                    <button type="button" class="date-picker-button" data-date-toggle="return" aria-label="@T("Return")">▦</button>
                </div>
            </div>

            <div class="travel-field traveller-field">
                <button type="button" class="traveller-button" data-traveller-toggle>
                    <span>@T("TravellersCabin")</span>
                    <strong data-traveller-summary>@TravellerSummary</strong>
                </button>
                <div class="traveller-panel" data-traveller-panel hidden>
                    <label class="form-label" for="cabin">@T("CabinClass")</label>
                    <select id="cabin" name="cabin" class="form-select" data-cabin-select>
                        @foreach (var cabin in Enum.GetValues<CabinClass>())
                        {
                            <option value="@cabin" selected="@(Cabin == cabin)">@CabinLabel(cabin)</option>
                        }
                    </select>

                    <div class="stepper-row">
                        <div>
                            <strong>@T("Adults")</strong>
                            <span>@T("Aged18")</span>
                        </div>
                        <div class="stepper">
                            <button type="button" data-step="adults" data-delta="-1">-</button>
                            <span data-count="adults">@Adults</span>
                            <button type="button" data-step="adults" data-delta="1">+</button>
                        </div>
                    </div>

                    <div class="stepper-row">
                        <div>
                            <strong>@T("Children")</strong>
                            <span>@T("Aged0To17")</span>
                        </div>
                        <div class="stepper">
                            <button type="button" data-step="children" data-delta="-1">-</button>
                            <span data-count="children">@Children</span>
                            <button type="button" data-step="children" data-delta="1">+</button>
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary w-100" data-traveller-apply>@T("Apply")</button>
                </div>
            </div>

            <input type="hidden" name="adults" value="@Adults" data-hidden-count="adults" />
            <input type="hidden" name="children" value="@Children" data-hidden-count="children" />
            <button type="submit" class="btn btn-primary flight-search-button">@T("Search")</button>
        </div>

        <div class="flight-filter-row">
            <label class="filter-check">
                <input type="checkbox" name="originNearby" value="true" checked="@OriginNearby" />
                <span>@T("AddNearbyAirports")</span>
            </label>
            <label class="filter-check">
                <input type="checkbox" name="destinationNearby" value="true" checked="@DestinationNearby" />
                <span>@T("AddNearbyAirports")</span>
            </label>
            <label class="filter-check">
                <input type="checkbox" name="directOnly" value="true" checked="@DirectOnly" />
                <span>@T("DirectFlights")</span>
            </label>
            <div class="filter-inline">
                <label for="currency">@T("Currency")</label>
                <div class="currency-control">
                    <span class="currency-glyph" aria-hidden="true">@CurrencySymbol(Currency)</span>
                    <input id="currency" name="currency" class="form-control currency-input" list="currency-options" maxlength="3" value="@Currency" />
                </div>
            </div>
            <div class="filter-inline">
                <label for="maxStops">@T("MaxStops")</label>
                <input id="maxStops" name="maxStops" class="form-control" type="number" min="0" max="4" value="@MaxStops" />
            </div>
            <div class="filter-inline">
                <label for="checkedBags">@T("CheckedBags")</label>
                <input id="checkedBags" name="checkedBags" class="form-control" type="number" min="0" max="9" value="@CheckedBags" />
            </div>
            <div class="filter-inline">
                <label for="targetPrice">@T("AlertTarget")</label>
                <input id="targetPrice" name="targetPrice" class="form-control" type="number" min="1" step="1" value="@TargetPrice" />
            </div>
            <button type="submit" name="saveAlert" value="true" class="btn btn-outline-light save-alert-button">@T("SaveAlert")</button>
        </div>
    </form>
</section>

<datalist id="currency-options">
    @foreach (var currency in Currencies)
    {
        <option value="@currency.Code" label="@($"{currency.Symbol} {currency.Name}")"></option>
    }
</datalist>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@if (offers.Count > 0)
{
    <div class="section-heading">
        <div>
            <h2>@T("FareResults")</h2>
            <p>@string.Format(CultureInfo.CurrentCulture, T("OffersFound"), offers.Count, Origin, Destination)</p>
        </div>
    </div>
    <div class="results-grid">
        @foreach (var offer in offers)
        {
            <article class="result-card">
                <div>
                    <div class="airline-identity">
                        <span class="airline-logo-fallback">@AirlineInitials(offer.Airline)</span>
                        <img class="airline-logo" src="@AirlineLogoUrl(offer.Airline)" alt="" loading="lazy" onload="this.previousElementSibling.hidden=true" onerror="this.hidden=true" />
                        <span>
                            <strong>@offer.Airline @offer.FlightNumber</strong>
                            <span>@offer.Provider</span>
                        </span>
                    </div>
                </div>
                <div>
                    <strong>@CurrencySymbol(offer.Currency) @offer.Price.ToString("0.##") @offer.Currency</strong>
                    <span>@offer.Stops @(offer.Stops == 1 ? T("Stop") : T("Stops")) · @FormatDuration(offer.Duration)</span>
                </div>
                <div>
                    <strong>@offer.DepartDate.ToString("dd/MM/yyyy")</strong>
                    <span>@offer.Origin @T("ToLower") @offer.Destination</span>
                </div>
                <div class="row-actions">
                    @if (!string.IsNullOrWhiteSpace(offer.BookingUrl) && offer.BookingUrl != "#")
                    {
                        <a class="btn btn-sm btn-outline-primary" href="@offer.BookingUrl" target="_blank" rel="noopener">@T("Open")</a>
                    }
                </div>
            </article>
        }
    </div>
}

@if (airlineLinks.Count > 0)
{
    <div class="section-heading">
        <div>
            <h2>@T("AirlineDirectSearch")</h2>
            <p>@T("AirlineDirectSubtitle")</p>
        </div>
    </div>
    <div class="airline-grid">
        @foreach (var link in airlineLinks)
        {
            <article class="airline-card">
                <div>
                    <strong>@link.Airline</strong>
                    <span>@link.Region</span>
                </div>
                <span class="carrier-pill">@link.Category</span>
                <a class="btn btn-sm btn-primary" href="@link.SearchUrl" target="_blank" rel="noopener">@T("SearchAirline")</a>
            </article>
        }
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "run")]
    public bool Run { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "saveAlert")]
    public bool SaveAlert { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "origin")]
    public string Origin { get; set; } = "JFK";

    [Parameter, SupplyParameterFromQuery(Name = "destination")]
    public string Destination { get; set; } = "Europe";

    [Parameter, SupplyParameterFromQuery(Name = "originType")]
    public string OriginType { get; set; } = nameof(LocationType.Airport);

    [Parameter, SupplyParameterFromQuery(Name = "destinationType")]
    public string DestinationType { get; set; } = nameof(LocationType.Continent);

    [Parameter, SupplyParameterFromQuery(Name = "depart")]
    public string Depart { get; set; } = DateTime.Today.AddDays(14).ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);

    [Parameter, SupplyParameterFromQuery(Name = "returnDate")]
    public string ReturnDate { get; set; } = DateTime.Today.AddDays(21).ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);

    [Parameter, SupplyParameterFromQuery(Name = "adults")]
    public int Adults { get; set; } = 1;

    [Parameter, SupplyParameterFromQuery(Name = "children")]
    public int Children { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "cabin")]
    public string CabinQuery { get; set; } = nameof(CabinClass.Economy);

    [Parameter, SupplyParameterFromQuery(Name = "directOnly")]
    public bool DirectOnly { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "originNearby")]
    public bool OriginNearby { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "destinationNearby")]
    public bool DestinationNearby { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "maxStops")]
    public int? MaxStops { get; set; } = 1;

    [Parameter, SupplyParameterFromQuery(Name = "checkedBags")]
    public int CheckedBags { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "currency")]
    public string Currency { get; set; } = "USD";

    [Parameter, SupplyParameterFromQuery(Name = "targetPrice")]
    public string? TargetPrice { get; set; }

    private static readonly IReadOnlyList<CurrencyOption> Currencies =
    [
        new("USD", "$", "US Dollar"),
        new("EUR", "€", "Euro"),
        new("GBP", "£", "British Pound"),
        new("MAD", "د.م.", "Moroccan Dirham"),
        new("CAD", "C$", "Canadian Dollar"),
        new("AUD", "A$", "Australian Dollar"),
        new("JPY", "¥", "Japanese Yen"),
        new("CNY", "¥", "Chinese Yuan"),
        new("AED", "د.إ", "UAE Dirham"),
        new("SAR", "﷼", "Saudi Riyal"),
        new("CHF", "CHF", "Swiss Franc"),
        new("SEK", "kr", "Swedish Krona"),
        new("NOK", "kr", "Norwegian Krone"),
        new("DKK", "kr", "Danish Krone"),
        new("BRL", "R$", "Brazilian Real"),
        new("MXN", "$", "Mexican Peso"),
        new("ZAR", "R", "South African Rand"),
        new("INR", "₹", "Indian Rupee"),
        new("SGD", "S$", "Singapore Dollar"),
        new("NZD", "NZ$", "New Zealand Dollar")
    ];

    private IReadOnlyList<FlightOffer> offers = [];
    private IReadOnlyList<AirlineSearchLink> airlineLinks = [];
    private List<FlightLocation> locations = [];
    private string? message;
    private CabinClass Cabin => Enum.TryParse<CabinClass>(CabinQuery, ignoreCase: true, out var cabin) ? cabin : CabinClass.Economy;
    private string TravellerSummary => $"{Adults + Children} {(Adults + Children == 1 ? T("Traveller") : T("Travellers"))}, {CabinLabel(Cabin)}";

    protected override async Task OnParametersSetAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        locations = await db.FlightLocations.AsNoTracking()
            .OrderBy(location => location.Type)
            .ThenBy(location => location.Name)
            .Take(2000)
            .ToListAsync();

        if (!Run && !SaveAlert)
        {
            return;
        }

        if (!TryBuildQuery(out var query, out message))
        {
            return;
        }

        NormalizeDisplay(query);

        if (SaveAlert)
        {
            await SaveAlertAsync(query);
        }

        offers = await FlightSearch.SearchAsync(query);
        airlineLinks = FlightSearch.GetAirlineSearchLinks(query);
        message = offers.Count == 0
            ? T("NoLiveProvider")
            : message;
    }

    private async Task SaveAlertAsync(FlightSearchQuery query)
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            message = T("LoginExpired");
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        db.PriceAlerts.Add(new PriceAlert
        {
            UserId = userId,
            OriginType = query.OriginType,
            Origin = query.Origin,
            DestinationType = query.DestinationType,
            Destination = query.Destination,
            DepartFrom = query.DepartFrom,
            DepartTo = query.DepartTo,
            ReturnFrom = query.ReturnFrom,
            ReturnTo = query.ReturnTo,
            Adults = query.Adults,
            Children = query.Children,
            Infants = query.Infants,
            Cabin = query.Cabin,
            DirectOnly = query.DirectOnly,
            MaxStops = query.MaxStops,
            CheckedBags = query.CheckedBags,
            Currency = query.Currency,
            TargetPrice = ParseTargetPrice()
        });
        await db.SaveChangesAsync();
        message = T("AlertSaved");
    }

    private bool TryBuildQuery(out FlightSearchQuery query, out string? validationMessage)
    {
        query = default!;
        validationMessage = null;

        if (!TryParseDate(Depart, out var departDate))
        {
            validationMessage = T("DepartDateInvalid");
            return false;
        }

        DateOnly? returnDate = null;
        if (!string.IsNullOrWhiteSpace(ReturnDate))
        {
            if (!TryParseDate(ReturnDate, out var parsedReturnDate))
            {
                validationMessage = T("ReturnDateInvalid");
                return false;
            }

            returnDate = parsedReturnDate;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        if (departDate < today)
        {
            validationMessage = T("DepartDatePast");
            return false;
        }

        if (returnDate is not null && returnDate.Value < today)
        {
            validationMessage = T("ReturnDatePast");
            return false;
        }

        if (returnDate is not null && returnDate.Value < departDate)
        {
            departDate = returnDate.Value;
            returnDate = null;
        }

        if (SaveAlert && (string.IsNullOrWhiteSpace(TargetPrice) ||
            !decimal.TryParse(TargetPrice, NumberStyles.Number, CultureInfo.InvariantCulture, out var targetPrice) ||
            targetPrice <= 0))
        {
            validationMessage = T("AlertTargetRequired");
            return false;
        }

        var originType = ParseLocationType(OriginType, Origin);
        var destinationType = ParseLocationType(DestinationType, Destination);
        var currency = string.IsNullOrWhiteSpace(Currency) ? "USD" : Currency.Trim().ToUpperInvariant();

        query = new FlightSearchQuery(
            originType,
            CleanLocationValue(Origin),
            destinationType,
            CleanLocationValue(Destination),
            departDate,
            departDate,
            returnDate,
            returnDate,
            Math.Clamp(Adults, 1, 9),
            Math.Clamp(Children, 0, 9),
            0,
            Cabin,
            DirectOnly,
            MaxStops,
            Math.Max(0, CheckedBags),
            currency);
        return true;
    }

    private void NormalizeDisplay(FlightSearchQuery query)
    {
        OriginType = query.OriginType.ToString();
        DestinationType = query.DestinationType.ToString();
        Depart = query.DepartFrom.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);
        ReturnDate = query.ReturnFrom?.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture) ?? "";
        Currency = query.Currency;
    }

    private LocationType ParseLocationType(string value, string locationValue)
    {
        if (Enum.TryParse<LocationType>(value, ignoreCase: true, out var parsed))
        {
            return parsed;
        }

        var exact = FindBestLocation(locationValue);
        return exact?.Type ?? (locationValue.Trim().Length == 3 ? LocationType.Airport : LocationType.City);
    }

    private FlightLocation? FindBestLocation(string value)
    {
        var query = CleanLocationValue(value);
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        return locations
            .OrderByDescending(location => location.Code.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(location => location.Name.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenBy(location => location.Type)
            .FirstOrDefault(location => MatchesLocation(location, query));
    }

    private static bool MatchesLocation(FlightLocation location, string value)
    {
        return location.Code.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            location.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (location.CountryName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            location.Continent.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static string CleanLocationValue(string value)
    {
        var trimmed = value.Trim();
        var separator = trimmed.IndexOf(" - ", StringComparison.Ordinal);
        return separator > 0 ? trimmed[..separator] : trimmed;
    }

    private static bool TryParseDate(string value, out DateOnly date)
    {
        return DateOnly.TryParseExact(value.Trim(), "dd/MM/yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out date) ||
            DateOnly.TryParseExact(value.Trim(), "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out date);
    }

    private static string CurrencySymbol(string? code)
    {
        return Currencies.FirstOrDefault(currency => currency.Code.Equals(code?.Trim(), StringComparison.OrdinalIgnoreCase))?.Symbol ?? "¤";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration <= TimeSpan.Zero ? T("DurationUnavailable") : $"{(int)duration.TotalHours} h {duration.Minutes} m";
    }

    private decimal ParseTargetPrice()
    {
        return decimal.TryParse(TargetPrice, NumberStyles.Number, CultureInfo.InvariantCulture, out var value) && value > 0
            ? value
            : 0;
    }

    private static string AirlineLogoUrl(string airline)
    {
        var code = AirlineLogoCode(airline);
        return $"https://images.kiwi.com/airlines/64/{Uri.EscapeDataString(code)}.png";
    }

    private static string AirlineLogoCode(string airline)
    {
        var trimmed = airline.Trim();
        if (trimmed.Length is 2 or 3 && trimmed.All(char.IsLetterOrDigit))
        {
            return trimmed.ToUpperInvariant();
        }

        return trimmed.ToLowerInvariant() switch
        {
            "american airlines" => "AA",
            "delta air lines" => "DL",
            "united airlines" => "UA",
            "british airways" => "BA",
            "lufthansa" => "LH",
            "air france" => "AF",
            "klm" => "KL",
            "iberia" => "IB",
            "royal air maroc" => "AT",
            "emirates" => "EK",
            "qatar airways" => "QR",
            "turkish airlines" => "TK",
            "easyjet" => "U2",
            "ryanair" => "FR",
            _ => new string(trimmed.Where(char.IsLetterOrDigit).Take(2).Select(char.ToUpperInvariant).ToArray()).PadRight(2, 'X')
        };
    }

    private static string AirlineInitials(string airline)
    {
        var words = airline.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length >= 2)
        {
            return string.Concat(words.Take(2).Select(word => char.ToUpperInvariant(word[0])));
        }

        return airline.Length >= 2 ? airline[..2].ToUpperInvariant() : airline.ToUpperInvariant();
    }

    private static string CabinLabel(CabinClass cabin)
    {
        return cabin switch
        {
            CabinClass.PremiumEconomy => T("PremiumEconomy"),
            CabinClass.Business => T("Business"),
            CabinClass.First => T("First"),
            _ => T("Economy")
        };
    }

    private static string T(string key) => UiText.T(key);

    private sealed record CurrencyOption(string Code, string Symbol, string Name);
}
