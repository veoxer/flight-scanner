    private AlertPolicyOptions alertPolicy = new();
    private int activeAlertCount;
    private int activeFlexibleAlertCount;
    private int activeSpecificAlertCount;
    private string? message;
    private bool messageIsError;
    private bool searchIsPending;
    private readonly HashSet<string> processedExecutionKeys = [];
    private static readonly TimeSpan SearchPageCacheDuration = TimeSpan.FromMinutes(30);
    private static readonly TimeSpan AlertSaveGateDuration = TimeSpan.FromSeconds(20);
    private static readonly ConcurrentDictionary<string, Lazy<Task<SearchPageCacheEntry>>> SearchPageCache = new(StringComparer.Ordinal);
    private static readonly ConcurrentDictionary<string, DateTimeOffset> RecentAlertSaveKeys = new(StringComparer.Ordinal);
    private static readonly IReadOnlyList<DayOfWeek> Weekdays =
    [
        DayOfWeek.Monday,
