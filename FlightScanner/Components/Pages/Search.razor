@page "/search"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@inject IFlightSearchService FlightSearch
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Search</PageTitle>

<section class="flight-hero">
    <div class="trip-mode-row">
        <button type="button" class="trip-mode-button">Return</button>
    </div>

    <EditForm Model="Model" FormName="search-form">
        <DataAnnotationsValidator />
        <div class="flight-search-bar">
            <div class="travel-field location-field">
                <label>From</label>
                <input class="travel-input"
                       value="@Model.Origin"
                       @oninput="OnOriginInput"
                       @onfocus='() => FocusLocation("origin")'
                       @onblur="BlurLocationAsync"
                       autocomplete="off"
                       placeholder="Country, city or airport" />
                @if (ShowSuggestions("origin"))
                {
                    <div class="location-menu">
                        @foreach (var location in LocationSuggestions(Model.Origin))
                        {
                            <button type="button" class="location-option" @onmousedown="() => SelectOrigin(location)">
                                <span class="location-kind">@location.Type</span>
                                <span>
                                    <strong>@LocationPrimary(location)</strong>
                                    <small>@LocationSecondary(location)</small>
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="travel-field location-field">
                <label>To</label>
                <input class="travel-input"
                       value="@Model.Destination"
                       @oninput="OnDestinationInput"
                       @onfocus='() => FocusLocation("destination")'
                       @onblur="BlurLocationAsync"
                       autocomplete="off"
                       placeholder="Country, city or airport" />
                @if (ShowSuggestions("destination"))
                {
                    <div class="location-menu">
                        @foreach (var location in LocationSuggestions(Model.Destination))
                        {
                            <button type="button" class="location-option" @onmousedown="() => SelectDestination(location)">
                                <span class="location-kind">@location.Type</span>
                                <span>
                                    <strong>@LocationPrimary(location)</strong>
                                    <small>@LocationSecondary(location)</small>
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="travel-field compact-field">
                <label>Depart</label>
                <input class="travel-input date-text-input"
                       value="@Model.DepartDateText"
                       @oninput="OnDepartDateInput"
                       data-flight-date="depart"
                       inputmode="numeric"
                       autocomplete="off"
                       placeholder="dd/mm/yyyy" />
            </div>

            <div class="travel-field compact-field">
                <label>Return</label>
                <input class="travel-input date-text-input"
                       value="@Model.ReturnDateText"
                       @oninput="OnReturnDateInput"
                       data-flight-date="return"
                       inputmode="numeric"
                       autocomplete="off"
                       placeholder="dd/mm/yyyy" />
            </div>

            <div class="travel-field traveller-field">
                <button type="button" class="traveller-button" @onclick="ToggleTravellerPanel">
                    <span>Travellers and cabin class</span>
                    <strong>@TravellerSummary</strong>
                </button>
                @if (showTravellerPanel)
                {
                    <div class="traveller-panel">
                        <label class="form-label">Cabin class</label>
                        <InputSelect class="form-select" @bind-Value="Model.Cabin">
                            @foreach (var cabin in Enum.GetValues<CabinClass>())
                            {
                                <option value="@cabin">@CabinLabel(cabin)</option>
                            }
                        </InputSelect>

                        <div class="stepper-row">
                            <div>
                                <strong>Adults</strong>
                                <span>Aged 18+</span>
                            </div>
                            <div class="stepper">
                                <button type="button" @onclick="() => ChangeAdults(-1)" disabled="@(Model.Adults <= 1)">−</button>
                                <span>@Model.Adults</span>
                                <button type="button" @onclick="() => ChangeAdults(1)">+</button>
                            </div>
                        </div>

                        <div class="stepper-row">
                            <div>
                                <strong>Children</strong>
                                <span>Aged 0 to 17</span>
                            </div>
                            <div class="stepper">
                                <button type="button" @onclick="() => ChangeChildren(-1)" disabled="@(Model.Children <= 0)">−</button>
                                <span>@Model.Children</span>
                                <button type="button" @onclick="() => ChangeChildren(1)">+</button>
                            </div>
                        </div>

                        <button type="button" class="btn btn-primary w-100" @onclick="ToggleTravellerPanel">Apply</button>
                    </div>
                }
            </div>

            <button type="button" class="btn btn-primary flight-search-button" @onclick="RunSearchAsync" disabled="@busy">
                @(busy ? "Searching..." : "Search")
            </button>
        </div>

        <div class="flight-filter-row">
            <label class="filter-check">
                <InputCheckbox @bind-Value="Model.OriginNearby" />
                <span>Add nearby airports</span>
            </label>
            <label class="filter-check">
                <InputCheckbox @bind-Value="Model.DestinationNearby" />
                <span>Add nearby airports</span>
            </label>
            <label class="filter-check">
                <InputCheckbox @bind-Value="Model.DirectOnly" />
                <span>Direct flights</span>
            </label>
            <div class="filter-inline">
                <label>Currency</label>
                <div class="currency-control">
                    <span class="currency-glyph" aria-hidden="true">@CurrencySymbol(Model.Currency)</span>
                    <InputText class="form-control currency-input" list="currency-options" maxlength="3" @bind-Value="Model.Currency" />
                </div>
            </div>
            <div class="filter-inline">
                <label>Max stops</label>
                <InputNumber class="form-control" @bind-Value="Model.MaxStops" />
            </div>
            <div class="filter-inline">
                <label>Checked bags</label>
                <InputNumber class="form-control" @bind-Value="Model.CheckedBags" />
            </div>
            <div class="filter-inline">
                <label>Alert target</label>
                <InputNumber class="form-control" @bind-Value="Model.TargetPrice" />
            </div>
            <button type="button" class="btn btn-outline-light save-alert-button" @onclick="SaveAlertAsync" disabled="@busy">Save alert</button>
        </div>
    </EditForm>
</section>

<datalist id="currency-options">
    @foreach (var currency in Currencies)
    {
        <option value="@currency.Code" label="@($"{currency.Symbol} {currency.Name}")"></option>
    }
</datalist>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@if (offers.Count > 0)
{
    <div class="section-heading">
        <div>
            <h2>Fare results</h2>
            <p>@offers.Count offer@(offers.Count == 1 ? "" : "s") found for @Model.Origin to @Model.Destination.</p>
        </div>
    </div>
    <div class="results-grid">
        @foreach (var offer in offers)
        {
            <article class="result-card">
                <div>
                    <strong>@offer.Airline @offer.FlightNumber</strong>
                    <span>@offer.Provider</span>
                </div>
                <div>
                    <strong>@CurrencySymbol(offer.Currency) @offer.Price.ToString("0.##") @offer.Currency</strong>
                    <span>@offer.Stops @(offer.Stops == 1 ? "stop" : "stops") · @FormatDuration(offer.Duration)</span>
                </div>
                <div>
                    <strong>@offer.DepartDate.ToString("dd/MM/yyyy")</strong>
                    <span>@offer.Origin to @offer.Destination</span>
                </div>
                <div class="row-actions">
                    @if (!string.IsNullOrWhiteSpace(offer.BookingUrl) && offer.BookingUrl != "#")
                    {
                        <a class="btn btn-sm btn-outline-primary" href="@offer.BookingUrl" target="_blank" rel="noopener">Open</a>
                    }
                </div>
            </article>
        }
    </div>
}

@if (airlineLinks.Count > 0)
{
    <div class="section-heading">
        <div>
            <h2>Airline direct search</h2>
            <p>Regular and low-cost airline booking pages for this route.</p>
        </div>
    </div>
    <div class="airline-grid">
        @foreach (var link in airlineLinks)
        {
            <article class="airline-card">
                <div>
                    <strong>@link.Airline</strong>
                    <span>@link.Region</span>
                </div>
                <span class="carrier-pill">@link.Category</span>
                <a class="btn btn-sm btn-primary" href="@link.SearchUrl" target="_blank" rel="noopener">Search airline</a>
            </article>
        }
    </div>
}

@code {
    private readonly SearchInput Model = new();

    private static readonly IReadOnlyList<CurrencyOption> Currencies =
    [
        new("USD", "$", "US Dollar"),
        new("EUR", "€", "Euro"),
        new("GBP", "£", "British Pound"),
        new("MAD", "د.م.", "Moroccan Dirham"),
        new("CAD", "C$", "Canadian Dollar"),
        new("AUD", "A$", "Australian Dollar"),
        new("JPY", "¥", "Japanese Yen"),
        new("CNY", "¥", "Chinese Yuan"),
        new("AED", "د.إ", "UAE Dirham"),
        new("SAR", "﷼", "Saudi Riyal"),
        new("CHF", "CHF", "Swiss Franc"),
        new("SEK", "kr", "Swedish Krona"),
        new("NOK", "kr", "Norwegian Krone"),
        new("DKK", "kr", "Danish Krone"),
        new("BRL", "R$", "Brazilian Real"),
        new("MXN", "$", "Mexican Peso"),
        new("ZAR", "R", "South African Rand"),
        new("INR", "₹", "Indian Rupee"),
        new("SGD", "S$", "Singapore Dollar"),
        new("NZD", "NZ$", "New Zealand Dollar")
    ];

    private IReadOnlyList<FlightOffer> offers = [];
    private IReadOnlyList<AirlineSearchLink> airlineLinks = [];
    private List<FlightLocation> locations = [];
    private bool busy;
    private bool showTravellerPanel;
    private string? activeLocationInput;
    private string? message;

    private string TravellerSummary => $"{Model.Adults + Model.Children} {(Model.Adults + Model.Children == 1 ? "traveller" : "travellers")}, {CabinLabel(Model.Cabin)}";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        locations = await db.FlightLocations.AsNoTracking()
            .OrderBy(location => location.Type)
            .ThenBy(location => location.Name)
            .ToListAsync();
    }

    private async Task RunSearchAsync()
    {
        if (!PrepareSearch(out var query, out message))
        {
            offers = [];
            airlineLinks = [];
            return;
        }

        busy = true;
        message = "Searching fares and preparing airline links...";
        offers = await FlightSearch.SearchAsync(query);
        airlineLinks = FlightSearch.GetAirlineSearchLinks(query);
        message = offers.Count == 0
            ? "No live provider fares returned. Add Amadeus credentials under Admin > Flight API, or use the airline-direct links below."
            : null;
        busy = false;
    }

    private async Task SaveAlertAsync()
    {
        if (!PrepareSearch(out _, out message))
        {
            return;
        }

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            message = "Login expired. Please sign in again.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        db.PriceAlerts.Add(Model.ToAlert(userId));
        await db.SaveChangesAsync();
        message = "Alert saved. The background scanner will check it automatically.";
    }

    private bool PrepareSearch(out FlightSearchQuery query, out string? validationMessage)
    {
        Model.OriginType = InferLocationType(Model.Origin);
        Model.DestinationType = InferLocationType(Model.Destination);

        if (!Model.TryBuildQuery(out query, out validationMessage))
        {
            return false;
        }

        Model.DepartDateText = query.DepartFrom.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);
        Model.ReturnDateText = query.ReturnFrom?.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture) ?? "";
        Model.Currency = query.Currency;
        return true;
    }

    private void OnOriginInput(ChangeEventArgs args)
    {
        Model.Origin = args.Value?.ToString() ?? "";
        Model.OriginType = InferLocationType(Model.Origin);
        activeLocationInput = "origin";
    }

    private void OnDestinationInput(ChangeEventArgs args)
    {
        Model.Destination = args.Value?.ToString() ?? "";
        Model.DestinationType = InferLocationType(Model.Destination);
        activeLocationInput = "destination";
    }

    private void OnDepartDateInput(ChangeEventArgs args)
    {
        Model.DepartDateText = args.Value?.ToString() ?? "";
    }

    private void OnReturnDateInput(ChangeEventArgs args)
    {
        Model.ReturnDateText = args.Value?.ToString() ?? "";
    }

    private void FocusLocation(string inputName)
    {
        activeLocationInput = inputName;
    }

    private async Task BlurLocationAsync()
    {
        await Task.Delay(150);
        activeLocationInput = null;
    }

    private bool ShowSuggestions(string inputName)
    {
        var value = inputName == "origin" ? Model.Origin : Model.Destination;
        return activeLocationInput == inputName && value.Trim().Length >= 2 && LocationSuggestions(value).Any();
    }

    private IEnumerable<FlightLocation> LocationSuggestions(string value)
    {
        var query = value.Trim();
        if (query.Length < 2)
        {
            return [];
        }

        return locations
            .Where(location => MatchesLocation(location, query))
            .OrderByDescending(location => location.Code.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(location => location.Name.StartsWith(query, StringComparison.OrdinalIgnoreCase))
            .ThenBy(location => location.Type)
            .ThenBy(location => location.Name)
            .Take(12);
    }

    private void SelectOrigin(FlightLocation location)
    {
        Model.Origin = LocationValue(location);
        Model.OriginType = location.Type;
        activeLocationInput = null;
    }

    private void SelectDestination(FlightLocation location)
    {
        Model.Destination = LocationValue(location);
        Model.DestinationType = location.Type;
        activeLocationInput = null;
    }

    private LocationType InferLocationType(string value)
    {
        var exact = FindBestLocation(value);
        return exact?.Type ?? (value.Trim().Length == 3 ? LocationType.Airport : LocationType.City);
    }

    private FlightLocation? FindBestLocation(string value)
    {
        var query = CleanLocationValue(value);
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        return locations
            .OrderByDescending(location => location.Code.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(location => location.Name.Equals(query, StringComparison.OrdinalIgnoreCase))
            .ThenBy(location => location.Type)
            .FirstOrDefault(location => MatchesLocation(location, query));
    }

    private void ToggleTravellerPanel()
    {
        showTravellerPanel = !showTravellerPanel;
    }

    private void ChangeAdults(int delta)
    {
        Model.Adults = Math.Clamp(Model.Adults + delta, 1, 9);
    }

    private void ChangeChildren(int delta)
    {
        Model.Children = Math.Clamp(Model.Children + delta, 0, 9);
    }

    public sealed class SearchInput
    {
        public LocationType OriginType { get; set; } = LocationType.Airport;

        [Required, StringLength(120, MinimumLength = 2)]
        public string Origin { get; set; } = "JFK";

        public LocationType DestinationType { get; set; } = LocationType.Continent;

        [Required, StringLength(120, MinimumLength = 2)]
        public string Destination { get; set; } = "Europe";

        [Required]
        public string DepartDateText { get; set; } = DateTime.Today.AddDays(14).ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);

        public string ReturnDateText { get; set; } = DateTime.Today.AddDays(21).ToString("dd/MM/yyyy", CultureInfo.InvariantCulture);

        [Range(1, 9)]
        public int Adults { get; set; } = 1;

        [Range(0, 9)]
        public int Children { get; set; }

        public CabinClass Cabin { get; set; }
        public bool DirectOnly { get; set; }
        public bool OriginNearby { get; set; }
        public bool DestinationNearby { get; set; }

        [Range(0, 4)]
        public int? MaxStops { get; set; } = 1;

        [Range(0, 9)]
        public int CheckedBags { get; set; }

        [Required, StringLength(3, MinimumLength = 3)]
        public string Currency { get; set; } = "USD";

        [Range(1, 999999)]
        public decimal TargetPrice { get; set; } = 400;

        public bool TryBuildQuery(out FlightSearchQuery query, out string? validationMessage)
        {
            query = default!;
            validationMessage = null;

            if (!TryParseDate(DepartDateText, out var departDate))
            {
                validationMessage = "Enter a depart date as dd/mm/yyyy.";
                return false;
            }

            DateOnly? returnDate = null;
            if (!string.IsNullOrWhiteSpace(ReturnDateText))
            {
                if (!TryParseDate(ReturnDateText, out var parsedReturnDate))
                {
                    validationMessage = "Enter a return date as dd/mm/yyyy.";
                    return false;
                }

                returnDate = parsedReturnDate;
            }

            var today = DateOnly.FromDateTime(DateTime.Today);
            if (departDate < today)
            {
                validationMessage = "Depart date cannot be earlier than today.";
                return false;
            }

            if (returnDate is not null && returnDate.Value < today)
            {
                validationMessage = "Return date cannot be earlier than today.";
                return false;
            }

            if (returnDate is not null && returnDate.Value < departDate)
            {
                departDate = returnDate.Value;
                returnDate = null;
            }

            var currency = string.IsNullOrWhiteSpace(Currency) ? "USD" : Currency.Trim().ToUpperInvariant();

            query = new FlightSearchQuery(
                OriginType,
                CleanLocationValue(Origin),
                DestinationType,
                CleanLocationValue(Destination),
                departDate,
                departDate,
                returnDate,
                returnDate,
                Math.Max(1, Adults),
                Math.Max(0, Children),
                0,
                Cabin,
                DirectOnly,
                MaxStops,
                Math.Max(0, CheckedBags),
                currency);
            return true;
        }

        public PriceAlert ToAlert(string userId)
        {
            if (!TryBuildQuery(out var query, out _))
            {
                throw new InvalidOperationException("Cannot create an alert from invalid search input.");
            }

            return new PriceAlert
            {
                UserId = userId,
                OriginType = query.OriginType,
                Origin = query.Origin,
                DestinationType = query.DestinationType,
                Destination = query.Destination,
                DepartFrom = query.DepartFrom,
                DepartTo = query.DepartTo,
                ReturnFrom = query.ReturnFrom,
                ReturnTo = query.ReturnTo,
                Adults = query.Adults,
                Children = query.Children,
                Infants = query.Infants,
                Cabin = query.Cabin,
                DirectOnly = query.DirectOnly,
                MaxStops = query.MaxStops,
                CheckedBags = query.CheckedBags,
                Currency = query.Currency,
                TargetPrice = TargetPrice
            };
        }
    }

    private static bool MatchesLocation(FlightLocation location, string value)
    {
        return location.Code.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            location.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (location.CountryName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false) ||
            location.Continent.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static string LocationValue(FlightLocation location)
    {
        return location.Type == LocationType.Airport ? location.Code : location.Name;
    }

    private static string LocationPrimary(FlightLocation location)
    {
        return location.Type == LocationType.Airport ? $"{location.Code} · {location.Name}" : location.Name;
    }

    private static string LocationSecondary(FlightLocation location)
    {
        return location.Type switch
        {
            LocationType.Continent => "Continent",
            LocationType.Country => $"{location.Continent} · Country",
            _ => $"{location.CountryName} · {location.Continent}"
        };
    }

    private static string CleanLocationValue(string value)
    {
        var trimmed = value.Trim();
        var separator = trimmed.IndexOf(" - ", StringComparison.Ordinal);
        return separator > 0 ? trimmed[..separator] : trimmed;
    }

    private static bool TryParseDate(string value, out DateOnly date)
    {
        return DateOnly.TryParseExact(value.Trim(), "dd/MM/yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out date) ||
            DateOnly.TryParseExact(value.Trim(), "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out date);
    }

    private static string CurrencySymbol(string? code)
    {
        return Currencies.FirstOrDefault(currency => currency.Code.Equals(code?.Trim(), StringComparison.OrdinalIgnoreCase))?.Symbol ?? "¤";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration <= TimeSpan.Zero ? "duration unavailable" : $"{(int)duration.TotalHours} h {duration.Minutes} m";
    }

    private static string CabinLabel(CabinClass cabin)
    {
        return cabin switch
        {
            CabinClass.PremiumEconomy => "Premium economy",
            CabinClass.Business => "Business",
            CabinClass.First => "First",
            _ => "Economy"
        };
    }

    private sealed record CurrencyOption(string Code, string Symbol, string Name);
}
