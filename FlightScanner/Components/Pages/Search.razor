@page "/search"
@attribute [Authorize]
@attribute [ExcludeFromInteractiveRouting]
@attribute [StreamRendering(false)]
@using System.Collections.Concurrent
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using FlightScanner.Features.Integrations
@using FlightScanner.Features.Localization
@inject IFlightSearchService FlightSearch
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@T("Search")</PageTitle>

<section class="flight-hero">
    <div class="trip-mode-row" data-trip-mode-group>
        <button type="button" class="trip-mode-button @(IsOneWay ? "" : "active")" data-trip-mode-option="Return">@T("Return")</button>
        <button type="button" class="trip-mode-button @(IsOneWay ? "active" : "")" data-trip-mode-option="OneWay">@T("OneWay")</button>
    </div>

    <form id="flight-search-form" method="get" action="/search" class="search-native-form" autocomplete="off" data-enhance="false">
        <input type="hidden" name="tripType" value="@TripType" data-trip-type-value />
        <input type="hidden" name="dateMode" value="@DateMode" data-date-mode-value />
        <input type="hidden" name="originType" data-location-type="origin" value="@OriginType" />
        <input type="hidden" name="destinationType" data-location-type="destination" value="@DestinationType" />
        <input type="hidden" name="originCode" data-location-code="origin" value="@OriginCode" />
        <input type="hidden" name="destinationCode" data-location-code="destination" value="@DestinationCode" />

        <div class="flight-search-bar">
            <div class="travel-field location-field" data-location-box="origin">
                <label for="origin">@T("From")</label>
                <div class="field-control-shell">
                    <input id="origin" name="origin" class="travel-input location-input" value="@Origin" data-location-input="origin" data-location-selected-value="@Origin" data-location-invalid-message="@T("ChooseSuggestedLocation")" autocomplete="off" placeholder="@T("CountryCityAirport")" required />
                    <button type="button" class="field-clear-button" data-location-clear="origin" aria-label="@T("Clear")" hidden="@string.IsNullOrWhiteSpace(Origin)">×</button>
                </div>
                <div class="location-menu" data-location-menu="origin" hidden></div>
            </div>

            <button type="button" class="route-swap-button" data-route-swap aria-label="@T("SwapRoute")">⇄</button>

            <div class="travel-field location-field" data-location-box="destination">
                <label for="destination">@T("To")</label>
                <div class="field-control-shell">
                    <input id="destination" name="destination" class="travel-input location-input" value="@Destination" data-location-input="destination" data-location-selected-value="@Destination" data-location-invalid-message="@T("ChooseSuggestedLocation")" autocomplete="off" placeholder="@T("CountryCityAirport")" required />
                    <button type="button" class="field-clear-button" data-location-clear="destination" aria-label="@T("Clear")" hidden="@string.IsNullOrWhiteSpace(Destination)">×</button>
                </div>
                <div class="location-menu" data-location-menu="destination" hidden></div>
            </div>

            <div class="travel-field date-mode-field">
                <label>@T("DateMode")</label>
                <div class="date-mode-toggle" data-date-mode-group>
                    <button type="button" class="date-mode-button @(!IsFlexibleDates ? "active" : "")" data-date-mode-option="Specific">@T("SpecificDates")</button>
                    <button type="button" class="date-mode-button @(IsFlexibleDates ? "active" : "")" data-date-mode-option="Flexible">@T("FlexibleDates")</button>
                </div>
            </div>

            <div class="travel-field compact-field date-time-field" data-specific-date-field hidden="@IsFlexibleDates">
                <label for="depart">@T("Depart")</label>
                <div class="date-picker-field">
                    <input id="depart" name="depart" class="travel-input date-text-input" value="@Depart" data-flight-date="depart" inputmode="none" autocomplete="off" placeholder="@T("AddDate")" readonly disabled="@IsFlexibleDates" />
                    <button type="button" class="field-clear-button" data-date-clear="depart" aria-label="@T("Clear")" disabled="@IsFlexibleDates" hidden="@string.IsNullOrWhiteSpace(Depart)">×</button>
                    <button type="button" class="date-picker-button" data-date-toggle="depart" aria-label="@T("Depart")" disabled="@IsFlexibleDates">▦</button>
                </div>
                <div class="date-time-window">
                    <label for="outboundTimeFrom">@T("OutboundTime")</label>
                    <div>
                        <select id="outboundTimeFrom" name="outboundTimeFrom" class="time-filter-input time-filter-select" disabled="@IsFlexibleDates" data-custom-select data-time-range="outbound-specific" data-time-bound="start">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(OutboundTimeFrom == option.Value)">@option.Label</option>
                            }
                        </select>
                        <span>@T("ToLower")</span>
                        <select name="outboundTimeTo" class="time-filter-input time-filter-select" disabled="@IsFlexibleDates" data-custom-select data-time-range="outbound-specific" data-time-bound="end">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(OutboundTimeTo == option.Value)">@option.Label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="travel-field compact-field date-time-field" data-return-field data-specific-date-field hidden="@(IsOneWay || IsFlexibleDates)">
                <label for="returnDate">@T("ReturnDate")</label>
                <div class="date-picker-field">
                    <input id="returnDate" name="returnDate" class="travel-input date-text-input" value="@ReturnDate" data-flight-date="return" inputmode="none" autocomplete="off" placeholder="@T("AddDate")" readonly disabled="@(IsOneWay || IsFlexibleDates)" />
                    <button type="button" class="field-clear-button" data-date-clear="return" aria-label="@T("Clear")" disabled="@(IsOneWay || IsFlexibleDates)" hidden="@string.IsNullOrWhiteSpace(ReturnDate)">×</button>
                    <button type="button" class="date-picker-button" data-date-toggle="return" aria-label="@T("ReturnDate")">▦</button>
                </div>
                <div class="date-time-window" data-return-time-field>
                    <label for="returnTimeFrom">@T("ReturnTime")</label>
                    <div>
                        <select id="returnTimeFrom" name="returnTimeFrom" class="time-filter-input time-filter-select" disabled="@IsOneWay" data-custom-select data-time-range="return-specific" data-time-bound="start">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(ReturnTimeFrom == option.Value)">@option.Label</option>
                            }
                        </select>
                        <span>@T("ToLower")</span>
                        <select name="returnTimeTo" class="time-filter-input time-filter-select" disabled="@IsOneWay" data-custom-select data-time-range="return-specific" data-time-bound="end">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(ReturnTimeTo == option.Value)">@option.Label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="travel-field compact-field" data-flexible-date-field hidden="@(!IsFlexibleDates)">
                <label for="flexibleMonth">@T("Month")</label>
                <select id="flexibleMonth" name="flexibleMonth" class="travel-input" data-custom-select data-custom-select-search="true">
                    @foreach (var month in Enumerable.Range(1, 12))
                    {
                        <option value="@month" selected="@(FlexibleMonth == month)">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month)</option>
                    }
                </select>
            </div>

            <div class="travel-field compact-field" data-flexible-date-field hidden="@(!IsFlexibleDates)">
                <label for="flexibleYear">@T("Year")</label>
                <input id="flexibleYear" name="flexibleYear" class="travel-input" type="number" min="2020" max="2100" value="@FlexibleYear" />
            </div>

            <div class="travel-field compact-field" data-flexible-date-field hidden="@(!IsFlexibleDates)">
                <label for="flexibleDepartureDay">@T("Weekday")</label>
                <select id="flexibleDepartureDay" name="flexibleDepartureDay" class="travel-input" data-custom-select>
                    @foreach (var day in Weekdays)
                    {
                        <option value="@day" selected="@(SelectedFlexibleDepartureDay == day)">@CultureInfo.CurrentCulture.DateTimeFormat.GetDayName(day)</option>
                    }
                </select>
            </div>

            <div class="travel-field compact-field" data-flexible-date-field data-flexible-stay-field hidden="@(!IsFlexibleDates || IsOneWay)">
                <label for="flexibleStayDays">@T("StayDays")</label>
                <input id="flexibleStayDays" name="flexibleStayDays" class="travel-input" type="number" min="1" max="365" value="@FlexibleStayDays" disabled="@IsOneWay" />
            </div>

            <div class="travel-field compact-field time-window-field" data-flexible-date-field hidden="@(!IsFlexibleDates)">
                <label>@T("OutboundTime")</label>
                <div class="date-time-window standalone-time-window">
                    <div>
                        <select name="outboundTimeFrom" class="time-filter-input time-filter-select" disabled="@(!IsFlexibleDates)" data-custom-select data-time-range="outbound-flexible" data-time-bound="start">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(OutboundTimeFrom == option.Value)">@option.Label</option>
                            }
                        </select>
                        <span>@T("ToLower")</span>
                        <select name="outboundTimeTo" class="time-filter-input time-filter-select" disabled="@(!IsFlexibleDates)" data-custom-select data-time-range="outbound-flexible" data-time-bound="end">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(OutboundTimeTo == option.Value)">@option.Label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="travel-field compact-field time-window-field" data-flexible-date-field data-flexible-return-only-field hidden="@(!IsFlexibleDates || IsOneWay)">
                <label>@T("ReturnTime")</label>
                <div class="date-time-window standalone-time-window">
                    <div>
                        <select name="returnTimeFrom" class="time-filter-input time-filter-select" disabled="@(!IsFlexibleDates || IsOneWay)" data-custom-select data-time-range="return-flexible" data-time-bound="start">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(ReturnTimeFrom == option.Value)">@option.Label</option>
                            }
                        </select>
                        <span>@T("ToLower")</span>
                        <select name="returnTimeTo" class="time-filter-input time-filter-select" disabled="@(!IsFlexibleDates || IsOneWay)" data-custom-select data-time-range="return-flexible" data-time-bound="end">
                            @foreach (var option in TimeOptions)
                            {
                                <option value="@option.Value" selected="@(ReturnTimeTo == option.Value)">@option.Label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="travel-field traveller-field">
                <button type="button" class="traveller-button" data-traveller-toggle>
                    <span>@T("TravellersCabin")</span>
                    <strong data-traveller-summary>@TravellerSummary</strong>
                </button>
                <div class="traveller-panel" data-traveller-panel hidden>
                    <label class="form-label" for="cabin">@T("CabinClass")</label>
                    <select id="cabin" name="cabin" class="form-select" data-cabin-select data-custom-select>
                        @foreach (var cabin in Enum.GetValues<CabinClass>())
                        {
                            <option value="@cabin" selected="@(Cabin == cabin)">@CabinLabel(cabin)</option>
                        }
                    </select>

                    <div class="stepper-row">
                        <div>
                            <strong>@T("Adults")</strong>
                            <span>@T("Aged18")</span>
                        </div>
                        <div class="stepper">
                            <button type="button" data-step="adults" data-delta="-1">-</button>
                            <span data-count="adults">@Adults</span>
                            <button type="button" data-step="adults" data-delta="1">+</button>
                        </div>
                    </div>

                    <div class="stepper-row">
                        <div>
                            <strong>@T("Children")</strong>
                            <span>@T("Aged0To17")</span>
                        </div>
                        <div class="stepper">
                            <button type="button" data-step="children" data-delta="-1">-</button>
                            <span data-count="children">@Children</span>
                            <button type="button" data-step="children" data-delta="1">+</button>
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary w-100" data-traveller-apply>@T("Apply")</button>
                </div>
            </div>

            <input type="hidden" name="adults" value="@Adults" data-hidden-count="adults" />
            <input type="hidden" name="children" value="@Children" data-hidden-count="children" />
            <button type="submit" name="run" value="true" class="btn btn-primary flight-search-button">@T("Search")</button>
        </div>

        <div class="flight-filter-row">
            <label class="filter-check">
                <input type="checkbox" name="nearbyAirports" value="true" checked="@NearbyAirports" />
                <span>@T("AddNearbyAirports")</span>
            </label>
            <label class="filter-check">
                <input type="checkbox" name="directOnly" value="true" checked="@DirectOnly" />
                <span>@T("DirectFlights")</span>
            </label>
            <div class="filter-inline">
                <label for="currency">@T("Currency")</label>
                <div class="currency-combobox" data-currency-combobox>
                    <input type="hidden" id="currency" name="currency" value="@Currency" data-currency-value />
                    <button type="button" class="currency-combobox-button" data-currency-toggle>
                        <span data-currency-symbol>@CurrencySymbol(Currency)</span>
                        <strong data-currency-code>@Currency</strong>
                    </button>
                    <div class="currency-menu" data-currency-menu hidden>
                        <input type="search" class="form-control" data-currency-search placeholder="@T("SearchCurrency")" />
                        <div class="currency-options" data-currency-options></div>
                    </div>
                </div>
            </div>
            <div class="filter-inline">
                <label for="maxStops">@T("MaxStops")</label>
                <input id="maxStops" name="maxStops" class="form-control" type="number" min="0" max="4" value="@MaxStops" />
            </div>
            <div class="filter-inline">
                <label for="checkedBags">@T("CheckedBags")</label>
                <input id="checkedBags" name="checkedBags" class="form-control" type="number" min="0" max="9" value="@CheckedBags" />
            </div>
        </div>
    </form>

    <div class="search-loading-overlay" data-search-loading hidden>
        <div class="search-loading-panel">
            <span class="search-loading-spinner" aria-hidden="true"></span>
            <strong>@T("SearchingFlights")</strong>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(messageIsError ? "alert-danger" : "alert-info") mt-3">@message</div>
}

@if (searchIsPending)
{
    <section class="results-preparing" aria-live="polite">
        <div class="results-preparing-heading">
            <span class="search-loading-spinner" aria-hidden="true"></span>
            <div>
                <strong>@T("PreparingResults")</strong>
                <span>@T("SearchingFlights")</span>
            </div>
        </div>
        <div class="results-preparing-grid" aria-hidden="true">
            @for (var index = 0; index < 3; index++)
            {
                <div class="result-skeleton-card">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            }
        </div>
    </section>
}
else
{
    <div data-results-cache-target>
        @if (offers.Count > 0)
        {
            <div data-results-cache-source>
                <div class="price-alert-entry">
                    <button type="button"
                            class="price-alert-button"
                            data-price-alert-open
                            data-policy-max="@alertPolicy.MaxAlertsPerUser"
                            data-policy-flexible="@alertPolicy.MaxFlexibleAlertsPerUser"
                            data-policy-specific="@alertPolicy.MaxSpecificAlertsPerUser"
                            data-active-total="@activeAlertCount"
                            data-active-flexible="@activeFlexibleAlertCount"
                            data-active-specific="@activeSpecificAlertCount"
                            data-alert-kind="@(IsFlexibleDates ? "Flexible" : "Specific")"
                            data-total-limit-message="@T("ActiveAlertLimitReached")"
                            data-flexible-limit-message="@T("ActiveFlexibleAlertLimitReached")"
                            data-specific-limit-message="@T("ActiveSpecificAlertLimitReached")">
                        <span class="price-alert-bell" aria-hidden="true"></span>
                        <strong>@T("GetPriceAlerts")</strong>
                    </button>
                </div>
                <div class="section-heading">
                    <div>
                        <h2>@T("FareResults")</h2>
                        <p>@string.Format(CultureInfo.CurrentCulture, T("OffersFound"), offers.Count, Origin, Destination)</p>
                    </div>
                    <div class="result-pagination-controls" data-result-pagination>
                        <label for="resultPageSize">@T("PageSize")</label>
                        <select id="resultPageSize" class="form-select" data-results-page-size data-custom-select>
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="all">@T("All")</option>
                        </select>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-results-prev>@T("Previous")</button>
                        <span data-results-page-status></span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-results-next>@T("Next")</button>
                    </div>
                </div>
                <div class="results-grid" data-results-grid>
                    @foreach (var offer in offers)
                    {
                        <details class="result-card itinerary-result"
                                 data-flight-result
                                 data-result-kind="@offer.ResultKind"
                                 data-return-token="@offer.DepartureToken"
                                 data-return-departure-id="@offer.Origin"
                                 data-return-arrival-id="@offer.Destination"
                                 data-return-outbound-date="@offer.DepartDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                 data-return-date="@FormatDateAttribute(offer.ReturnDate)"
                                 data-currency="@offer.Currency"
                                 data-return-title="@T("ReturnFlight")"
                                 data-loading-text="@T("LoadingReturnFlight")"
                                 data-error-text="@T("ReturnFlightUnavailable")"
                                 data-price-symbol="@CurrencySymbol(offer.Currency)"
                                 data-duration-label="@T("TravelTime")"
                                 data-layover-label="@T("Layover")"
                                 data-emissions-label="@T("EmissionsEstimate")"
                                 data-co2-label="@T("KgCo2e")">
                            <summary class="result-summary">
                                <div class="airline-identity">
                                    <span class="airline-logo-fallback">@AirlineInitials(offer.Airline)</span>
                                    <img class="airline-logo" src="@AirlineLogoUrl(offer)" alt="" loading="lazy" onload="this.previousElementSibling.hidden=true" onerror="this.hidden=true" />
                                    <span>
                                        <strong>@offer.Airline @offer.FlightNumber</strong>
                                        <span>@offer.TripType · @offer.Provider</span>
                                    </span>
                                </div>
                                <div>
                                    <strong>@CurrencySymbol(offer.Currency) @offer.Price.ToString("0.##") @offer.Currency</strong>
                                    <span>@PriceSubtitle(offer)</span>
                                </div>
                                <div>
                                    <strong>@offer.DepartDate.ToString("dd/MM/yyyy")</strong>
                                    <span>@offer.Origin @T("ToLower") @offer.Destination</span>
                                </div>
                                <div>
                                    <strong>@(offer.CarbonEmissionsGrams is { } grams ? $"{FormatKilograms(grams)} {T("KgCo2e")}" : T("Details"))</strong>
                                    <span>@offer.Stops @(offer.Stops == 1 ? T("Stop") : T("Stops")) · @FormatDuration(offer.Duration)</span>
                                </div>
                                <span class="expand-chevron" aria-hidden="true">⌄</span>
                            </summary>

                            <div class="itinerary-details">
                                @foreach (var leg in offer.ItineraryLegs)
                                {
                                    <section class="flight-leg">
                                        <div class="flight-leg-heading">
                                            <div>
                                                <strong>@LegTitle(leg.Kind)</strong>
                                                <span>@(leg.Date?.ToString("ddd, dd MMM", CultureInfo.CurrentCulture) ?? T("DateUnavailable"))</span>
                                            </div>
                                            <span>@T("TravelTime"): @FormatDuration(leg.Duration)</span>
                                        </div>

                                        <div class="flight-timeline">
                                            @for (var segmentIndex = 0; segmentIndex < leg.Segments.Count; segmentIndex++)
                                            {
                                                var segment = leg.Segments[segmentIndex];
                                                <div class="flight-segment">
                                                    <div class="timeline-rail">
                                                        <span></span>
                                                        <i></i>
                                                        <span></span>
                                                    </div>
                                                    <div class="segment-main">
                                                        <div class="segment-airports">
                                                            <strong>@FormatTime(segment.DepartureAirport.Time)</strong>
                                                            <span>@AirportLabel(segment.DepartureAirport)</span>
                                                            <strong>@FormatTime(segment.ArrivalAirport.Time)</strong>
                                                            <span>@AirportLabel(segment.ArrivalAirport)</span>
                                                        </div>
                                                        <div class="segment-meta">
                                                            <span>@FormatDuration(segment.Duration)</span>
                                                            <span>@segment.Airline</span>
                                                            @if (!string.IsNullOrWhiteSpace(segment.TravelClass))
                                                            {
                                                                <span>@segment.TravelClass</span>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(segment.Airplane))
                                                            {
                                                                <span>@segment.Airplane</span>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(segment.FlightNumber))
                                                            {
                                                                <span>@segment.FlightNumber</span>
                                                            }
                                                        </div>
                                                        @if (segment.Extensions.Count > 0)
                                                        {
                                                            <div class="flight-tags">
                                                                @foreach (var item in segment.Extensions.Take(4))
                                                                {
                                                                    <span>@item</span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>

                                                @if (segmentIndex < leg.Layovers.Count)
                                                {
                                                    var layover = leg.Layovers[segmentIndex];
                                                    <div class="layover-row">
                                                        <span>@T("Layover"): @FormatDuration(layover.Duration)</span>
                                                        <strong>@layover.Name @(!string.IsNullOrWhiteSpace(layover.Code) ? $"({layover.Code})" : "")</strong>
                                                        @if (layover.Overnight)
                                                        {
                                                            <em>@T("Overnight")</em>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </section>
                                }

                                <div class="flight-detail-side">
                                    @if (offer.CarbonEmissionsGrams is { } emissions)
                                    {
                                        <span>@T("EmissionsEstimate"): @FormatKilograms(emissions) @T("KgCo2e")</span>
                                    }
                                    @if (offer.EmissionsDifferencePercent is { } difference)
                                    {
                                        <span>@T("EmissionsDifference"): @FormatSignedPercent(difference)</span>
                                    }
                                    @foreach (var item in offer.Extensions.Take(4))
                                    {
                                        <span>@item</span>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(offer.BookingUrl) && offer.BookingUrl != "#")
                                {
                                    <div class="row-actions itinerary-actions">
                                        <a class="btn btn-sm btn-outline-primary" href="@offer.BookingUrl" target="_blank" rel="noopener">@T("Open")</a>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                </div>
            </div>
        }
    </div>
}

@if (!searchIsPending && offers.Count > 0)
{
    <div class="price-alert-modal"
         data-price-alert-modal
         data-required-message="@T("AlertTargetRequired")"
         data-order-message="@T("AlertMinGreaterThanMax")"
         hidden>
        <div class="price-alert-backdrop" data-price-alert-close></div>
        <section class="price-alert-dialog" role="dialog" aria-modal="true" aria-labelledby="priceAlertTitle">
            <header>
                <div>
                    <h2 id="priceAlertTitle">@T("GetPriceAlerts")</h2>
                    <p>@T("PriceAlertModalText")</p>
                </div>
                <button type="button" data-price-alert-close aria-label="@T("Cancel")">×</button>
            </header>
            <div class="alert alert-danger" data-price-alert-error hidden></div>
            <input type="hidden" name="targetFilterCount" value="2" form="flight-search-form" />
            <input type="hidden" name="targetMode" value="Max" form="flight-search-form" />
            <input type="hidden" name="targetMode2" value="Min" form="flight-search-form" />
            <div class="price-alert-fields">
                <div>
                    <label class="form-label" for="targetPrice">@T("MaxFare")</label>
