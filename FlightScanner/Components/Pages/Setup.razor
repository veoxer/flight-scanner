@page "/setup"
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@using FlightScanner.Features.Localization
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject SetupState SetupState
@inject NavigationManager Navigation

<PageTitle>@UiText.T("Setup")</PageTitle>

<div class="setup-shell">
    <div>
        <p class="eyebrow">@UiText.T("FirstOpening")</p>
        <h1>@UiText.T("CreateAdminUser")</h1>
        <p class="lead">@UiText.T("SetupLead")</p>
    </div>

    @if (isComplete)
    {
        <div class="alert alert-info">@UiText.T("SetupComplete")</div>
        <a class="btn btn-primary" href="/">@UiText.T("GoToDashboard")</a>
    }
    else
    {
        <EditForm Model="Input" method="post" OnValidSubmit="CreateAdminAsync" FormName="setup-admin" class="panel-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <label class="form-label">@UiText.T("DisplayName")</label>
            <InputText class="form-control" @bind-Value="Input.DisplayName" />
            <ValidationMessage For="() => Input.DisplayName" class="text-danger" />

            <label class="form-label mt-3">@UiText.T("Email")</label>
            <InputText class="form-control" type="email" @bind-Value="Input.Email" />
            <ValidationMessage For="() => Input.Email" class="text-danger" />

            <label class="form-label mt-3">@UiText.T("Password")</label>
            <InputText class="form-control" type="password" @bind-Value="Input.Password" />
            <ValidationMessage For="() => Input.Password" class="text-danger" />

            <button class="btn btn-primary mt-4" type="submit" disabled="@busy">@UiText.T("CreateAdmin")</button>
        </EditForm>
    }

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-danger mt-3">@message</div>
    }
</div>

@code {
    private bool isComplete;
    private bool busy;
    private string? message;

    [SupplyParameterFromForm]
    private SetupInput Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
        isComplete = await SetupState.IsCompleteAsync();
    }

    private async Task CreateAdminAsync()
    {
        busy = true;
        message = null;

        var user = new ApplicationUser
        {
            UserName = Input.Email,
            Email = Input.Email,
            EmailConfirmed = true,
            DisplayName = Input.DisplayName,
            CreatedAt = DateTimeOffset.UtcNow
        };

        var result = await UserManager.CreateAsync(user, Input.Password);
        if (!result.Succeeded)
        {
            message = string.Join(" ", result.Errors.Select(error => error.Description));
            busy = false;
            return;
        }

        await UserManager.AddToRolesAsync(user, ["Admin", "User"]);
        await SetupState.MarkCompleteAsync();
        await SignInManager.SignInAsync(user, isPersistent: true);
        Navigation.NavigateTo("/", replace: true);
    }

    private sealed class SetupInput
    {
        [Required]
        public string DisplayName { get; set; } = "Admin";

        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [MinLength(10)]
        public string Password { get; set; } = "";
    }
}
