@page "/Error"
@using System.Diagnostics
@using FlightScanner.Features.Localization

<PageTitle>@UiText.T("ErrorTitle")</PageTitle>

<h1 class="text-danger">@UiText.T("ErrorTitle")</h1>
<h2 class="text-danger">@UiText.T("ErrorSubtitle")</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@UiText.T("RequestId"):</strong> <code>@RequestId</code>
    </p>
}

<h3>@UiText.T("DevelopmentMode")</h3>
<p>@UiText.T("DevelopmentModeText")</p>
<p>@UiText.T("DevelopmentWarning")</p>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
