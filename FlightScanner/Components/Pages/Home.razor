@page "/"
@attribute [AllowAnonymous]
@using FlightScanner.Features.Localization
@inject SetupState SetupState
@inject NavigationManager Navigation

<PageTitle>Flight Scanner</PageTitle>

<section class="hero-band">
    <div>
        <p class="eyebrow">@UiText.T("HomeEyebrow")</p>
        <h1>Flight Scanner</h1>
        <p class="lead">@UiText.T("HomeLead")</p>
        <AuthorizeView>
            <Authorized>
                <a class="btn btn-primary btn-lg main-pg-btn" href="search">@UiText.T("SearchFlights")</a>
                <a class="btn btn-outline-secondary btn-lg ms-2 main-pg-btn" href="alerts">@UiText.T("ViewAlerts")</a>
            </Authorized>
            <NotAuthorized>
                <a class="btn btn-primary btn-lg" href="Account/Login">@UiText.T("Login")</a>
                <a class="btn btn-outline-secondary btn-lg ms-2" href="Account/Register">@UiText.T("Register")</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</section>

<section class="metrics-grid">
    <div>
        <strong>@UiText.T("LocationScope")</strong>
        <span>@UiText.T("LocationScopeText")</span>
    </div>
    <div>
        <strong>@UiText.T("Alerts")</strong>
        <span>@UiText.T("AlertsMetricText")</span>
    </div>
    <div>
        <strong>@UiText.T("DataSource")</strong>
        <span>@UiText.T("DataSourceText")</span>
    </div>
</section>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!await SetupState.IsCompleteAsync())
        {
            Navigation.NavigateTo("/setup", replace: true);
        }
    }
}
