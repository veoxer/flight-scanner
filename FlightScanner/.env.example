# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
AllowedHosts=localhost

# PostgreSQL: use either FLIGHTSCANNER_DATABASE_URL or the split POSTGRES_* values.
# FLIGHTSCANNER_DATABASE_URL=Host=postgres;Port=5432;Database=flightscanner;Username=flightscanner;Password=change-me;Pooling=true
# POSTGRES_URL=postgres://flightscanner:change-me@postgres:5432/flightscanner?sslmode=disable
DOCKER_NETWORK=net_internal
POSTGRES_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=flightscanner
POSTGRES_USER=flightscanner
POSTGRES_PASSWORD=change-me
POSTGRES_SSL_MODE=Disable

# Persist auth cookie/data-protection keys across container restarts.
FLIGHTSCANNER_DATA_PROTECTION_KEYS_PATH=/var/lib/flightscanner/keys
FLIGHTSCANNER_USE_DUMMY_FLIGHT_DATA=false

# Public world location catalog import from OurAirports.
LOCATION_DATA_IMPORT_ENABLED=true
LOCATION_DATA_IMPORT_REFRESH=false
LOCATION_IDENTIFIER_IMPORT_ENABLED=true
LOCATION_IDENTIFIER_IMPORT_REFRESH=false
LOCATION_IDENTIFIER_IMPORT_CITY_BATCH_SIZE=5000
LOCATION_IDENTIFIER_IMPORT_MAX_CITY_PAGES=200

# Optional integration seed values. You can also enter/update these in the admin UI later.
FLIGHT_PROVIDER_TYPE=SerpApi
SERPAPI_API_KEY=
SERPAPI_API_KEYS=
FLIGHT_PROVIDER_URL=
FLIGHT_PROVIDER_HTTP_METHOD=POST
FLIGHT_PROVIDER_HEADERS_JSON={}
FLIGHT_PROVIDER_BODY_TEMPLATE=
FLIGHT_PROVIDER_PRICE_JSON_PATH=$.offers[0].price
FLIGHT_PROVIDER_CURRENCY_JSON_PATH=$.offers[0].currency
FLIGHT_PROVIDER_URL_JSON_PATH=$.offers[0].url

# Optional reminder channel seed values. You can also enter/update these in Admin > Reminders.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=

WHATSAPP_API_URL=
WHATSAPP_HTTP_METHOD=POST
WHATSAPP_HEADERS_JSON={}
WHATSAPP_TO=
WHATSAPP_BODY_TEMPLATE={"to":"{{to}}","message":"{{message}}"}

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
